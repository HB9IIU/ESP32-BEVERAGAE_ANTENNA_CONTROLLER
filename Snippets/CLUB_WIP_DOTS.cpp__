    uint16_t fill = tft.color565(90, 90, 90);
    uint16_t border = TFT_LIGHTGREY;

    tft.fillRoundRect(TRX_SDR_X, TRX_SDR_Y, TRX_SDR_W, TRX_SDR_H, TRX_SDR_R, fill);
    tft.drawRoundRect(TRX_SDR_X, TRX_SDR_Y, TRX_SDR_W, TRX_SDR_H, TRX_SDR_R, border);

    // Label depends on state
    const char *label = gSDRmode ? "SDR" : "TRX";

    tft.setTextDatum(MC_DATUM);
    tft.setTextFont(2);
    tft.setTextSize(1);

    // tft.setFreeFont(&JetBrainsMono_Bold8pt7b);
    tft.setTextColor(TFT_WHITE, fill);
    tft.drawString(label, TRX_SDR_X + TRX_SDR_W / 2, TRX_SDR_Y + TRX_SDR_H / 2);

    drawn = true;
}

bool hitKeypadNavButton(uint16_t x, uint16_t y)
{
    return (x >= KEYPAD_NAV_X && x < (KEYPAD_NAV_X + KEYPAD_NAV_W) &&
            y >= KEYPAD_NAV_Y && y < (KEYPAD_NAV_Y + KEYPAD_NAV_H));
}

bool hitTRX_SDRButton(uint16_t x, uint16_t y)
{
    return (gView == VIEW_DIAL &&
            x >= TRX_SDR_X && x < (TRX_SDR_X + TRX_SDR_W) &&
            y >= TRX_SDR_Y && y < (TRX_SDR_Y + TRX_SDR_H));
}

void onTRX_SDRButtonPressed()
{
    gSDRmode = !gSDRmode;

    // ON for SDR / OFF for TRX (as requested)
    digitalWrite(PIN_REL_SDR_TRX, gSDRmode ? HIGH : LOW);

    Serial.printf("[UI ] TRX/SDR toggle -> %s  (PIN_REL_SDR_TRX=%s)\n",
                  gSDRmode ? "SDR" : "TRX",
                  gSDRmode ? "ON" : "OFF");

    // redraw button label
    drawTRX_SDRButton(true);
}

void enterKeypadView()
{
    gView = VIEW_KEYPAD;

    // Draw the real keypad UI (from the KEYPAD.cpp__ code you integrated)
    drawUI();

    // Optional: ensure outputs match current button states
    // (safe even if nothing changed)
    pcfApplyFromButtons();
}

void exitKeypadView()
{
    gView = VIEW_DIAL;

    // Rebuild the dial page exactly like your normal flow
    displayImageOnTFT("greatcircleMap.png");
    initAntennaDial();
    drawModeIndicator(true);
    updateDynamicCornerLabels(true);
    drawLocalAndUTCTime(240, 10);
    drawKeypadNavButton(true);
    drawTRX_SDRButton(true);
}
#define PCF_DEBUG 1

void pcfApplyFromButtons()
{
    uint8_t v = 0;
    for (uint8_t i = 0; i < BTN_COUNT; i++)
    {
        if (b[i].active)
            v |= (1u << i);
    }

    uint8_t out = PCF_ACTIVE_LOW ? (uint8_t)~v : v;

#if PCF_DEBUG
    static bool first = true;
    static uint8_t lastOut = 0xFF;

    // Print only when value changes (keeps Serial readable)
    if (first || out != lastOut)
    {
        Serial.printf("[PCF] UI=0x%02X -> OUT=0x%02X  (addr=0x%02X)%s\n",
                      v, out, PCF_ADDR, PCF_ACTIVE_LOW ? " active-LOW" : "");

        Serial.print("[PCF] OUT bits P7..P0 = ");
        for (int8_t bit = 7; bit >= 0; bit--)
        {
            Serial.print((out >> bit) & 1);
        }
        Serial.println();

        first = false;
        lastOut = out;
    }
#endif

    pcf.write8(out);

#if PCF_DEBUG
    int err = pcf.lastError(); // resets error to OK after reading
    if (err != PCF8574_OK)
    {
        Serial.printf("[PCF] I2C error: 0x%02X\n", err);
    }
#endif
}

// ============================================================
// FIXED layout for 480x320 with top & bottom margins
// ============================================================
void layoutUI_480x320()
{
    const int16_t S = 74;  // square button size
    const int16_t GX = 24; // horizontal gap
    const int16_t GY = 24; // vertical gap
    const int16_t TOP_MARGIN = 0;
    const int16_t LH = 18; // label height

    const int16_t totalW = 4 * S + 3 * GX;
    const int16_t startX = (480 - totalW) / 2;

    const int16_t row1Y = TOP_MARGIN + 20;
    const int16_t row2Y = row1Y + S + LH + GY;

    static const char *nums[BTN_COUNT] = {"1", "2", "3", "4", "5", "6", "7", "8"};

    for (int i = 0; i < 8; i++)
    {
        int col = i % 4;
        int row = i / 4;

        b[i].s = S;
        b[i].x = startX + col * (S + GX);
        b[i].y = (row == 0) ? row1Y : row2Y;
        b[i].num = nums[i];
        b[i].label = labels[i];
        b[i].active = false;
    }

    btnReturn.x = startX;
    btnReturn.w = totalW;
    btnReturn.h = 44;
    btnReturn.y = 320 - btnReturn.h - 10;
    btnReturn.text = "Return";
}

// ------------------------------------------------------------
// DRAWING FUNCTIONS
// ------------------------------------------------------------
void drawUI()
{
    tft.fillScreen(TFT_BLACK);
    for (uint8_t i = 0; i < BTN_COUNT; i++)
        drawToggle(i);
    drawReturn();
}

void drawToggle(uint8_t i)
{
    const ToggleBtn &bt = b[i];

    // Geometry
    const int16_t r = 10;      // corner radius
    const uint8_t borderT = 3; // border thickness in pixels

    // Colors
    uint16_t fill = bt.active ? tft.color565(40, 220, 90) : tft.color565(220, 40, 40);
    uint16_t border = TFT_WHITE; // single border color
    uint16_t text = bt.active ? TFT_BLACK : TFT_WHITE;
    uint16_t labelC = tft.color565(210, 210, 210);

    // --- Button body ---
    tft.fillRoundRect(bt.x, bt.y, bt.s, bt.s, r, fill);

    // --- Single thick border (no "double-outline gap") ---
    // Draw several concentric outlines. This stays visually continuous.
    for (uint8_t k = 0; k < borderT; k++)
    {
        tft.drawRoundRect(bt.x + k, bt.y + k, bt.s - 2 * k, bt.s - 2 * k, r - k, border);
    }

    // --- Big number ---
    tft.setTextDatum(MC_DATUM);
    tft.setFreeFont(&FreeSansBold18pt7b);
    tft.setTextColor(text, fill);
    tft.drawString(bt.num, bt.x + bt.s / 2, bt.y + bt.s / 2 + 2);

    // --- Label under the button ---
    tft.fillRect(bt.x, bt.y + bt.s + 2, bt.s, 20, TFT_BLACK);
    tft.setTextDatum(TC_DATUM);
    tft.setFreeFont(&FreeSans9pt7b);
    tft.setTextColor(labelC, TFT_BLACK);
    tft.drawString(bt.label, bt.x + bt.s / 2, bt.y + bt.s + 16);
}

void drawReturn()
{
    const int16_t r = 10;
    uint16_t fill = tft.color565(30, 30, 30);
    uint16_t border = tft.color565(160, 160, 160);

    tft.fillRoundRect(btnReturn.x, btnReturn.y, btnReturn.w, btnReturn.h, r, fill);
    tft.drawRoundRect(btnReturn.x, btnReturn.y, btnReturn.w, btnReturn.h, r, border);

    tft.setTextDatum(MC_DATUM);
    tft.setFreeFont(&FreeSansBold12pt7b);
    tft.setTextColor(TFT_WHITE, fill);
    tft.drawString(btnReturn.text, btnReturn.x + btnReturn.w / 2,
                   btnReturn.y + btnReturn.h / 2 + 2);
}

// ------------------------------------------------------------
// HIT DETECTION + CALLBACKS
// ------------------------------------------------------------
int hitToggle(uint16_t x, uint16_t y)
{
    for (int i = 0; i < BTN_COUNT; i++)
    {
        if (x >= b[i].x && x < (b[i].x + b[i].s) &&
            y >= b[i].y && y < (b[i].y + b[i].s))
        {
            return i;
        }
    }
    return -1;
}

bool hitReturn(uint16_t x, uint16_t y)
{
    return (x >= btnReturn.x && x < (btnReturn.x + btnReturn.w) &&
            y >= btnReturn.y && y < (btnReturn.y + btnReturn.h));
}

void onReturnPressed()
{
    // Return from keypad page back to your normal UI
    gView = VIEW_DIAL;

    displayImageOnTFT("greatcircleMap.png");
    initAntennaDial();
    drawModeIndicator(true);
    updateDynamicCornerLabels(true);
    drawLocalAndUTCTime(240, 10);
    drawKeypadNavButton(true);
    drawTRX_SDRButton(true);
}

void keypadTick()
{
    static bool fingerDown = false;
    static uint32_t lastTouchMs = 0;

    uint16_t x, y;
    bool touched = tft.getTouch(&x, &y);

    if (touched)
    {
        lastUserInteractionMs = millis(); // counts as user activity

        if (fingerDown)
            return;
        if (millis() - lastTouchMs < 160)
            return;

        fingerDown = true;
        lastTouchMs = millis();

        if (hitReturn(x, y))
        {
            onReturnPressed();
            return;
        }

        int idx = hitToggle(x, y);
        if (idx >= 0)
        {
            b[idx].active = !b[idx].active;
            drawToggle((uint8_t)idx);

            // Sync PCF outputs P0..P7
            pcfApplyFromButtons();

            Serial.printf("[UI] Button %d -> %s\n", idx + 1, b[idx].active ? "ON" : "OFF");
            return;
        }

        return; // empty tap = no action
    }
    else
    {
        fingerDown = false;
    }
}

// ============================================================================
//                                    SETUP
// ============================================================================
void setup()
{
    // ──────────────────────────────────────────────
    // 1️⃣ Serial console & startup diagnostics
    // ──────────────────────────────────────────────
    Serial.begin(115200);

    displayIntroBanner(); // Visual + serial intro banner
    printSystemInfo();    // CPU, memory, flash, PSRAM summary
    mountAndListFiles();  // LittleFS mount + file listing

    // ──────────────────────────────────────────────
    // 2️⃣  hardware initialization
    // ──────────────────────────────────────────────
    pinMode(TFT_BLP, OUTPUT); // TFT backlight control
    initEncoderPins();        // Rotary encoder GPIO setup

    // HT9200A DTMF
    pinMode(PIN_DIN, OUTPUT);
    pinMode(PIN_CLK, OUTPUT);
    pinMode(PIN_CS, OUTPUT);
    digitalWrite(PIN_DIN, LOW);
    digitalWrite(PIN_CLK, HIGH);
    digitalWrite(PIN_CS, LOW);

    // LEFT and RIGHT buttons
    pinMode(PIN_PBL, INPUT); // GPIO34 (external pull-up required)
    pinMode(PIN_PBR, INPUT); // GPIO35 (external pull-up required)

    // SDR-TRX Relay control
    pinMode(PIN_REL_SDR_TRX, OUTPUT);
    digitalWrite(PIN_REL_SDR_TRX, gSDRmode ? HIGH : LOW); // start consistent with label

    tft.init();         // Initialize TFT controller
    tft.setRotation(1); // Landscape orientation
    tft.fillScreen(TFT_BLACK);
    setPanelGamma_TFT_eSPI();

    // Apply stored touchscreen calibration (or recalibrate if missing)
    checkAndApplyTFTCalibrationData(false);

    // Optional standalone encoder test (disabled in normal operation)
    // encodertestTFT();

    // ──────────────────────────────────────────────
    // 3️⃣ Boot splash screen
    // ──────────────────────────────────────────────
    digitalWrite(TFT_BLP, LOW);    // Backlight off for clean splash
    displayImageOnTFT("logo.png"); // Startup logo
    digitalWrite(TFT_BLP, HIGH);   // Backlight on

    // ──────────────────────────────────────────────
    // 4️⃣ Define TFT color palette (used globally)
    // ──────────────────────────────────────── ──────
    TftGrey = tft.color565(100, 100, 100);
    TftRed = tft.color565(255, 0, 0);
    TftYellow = tft.color565(255, 255, 0);
    TftGreen = tft.color565(0, 255, 0);

    // ──────────────────────────────────────────────
    // 5️⃣ Factory reset (encoder button held at boot)
    // ──────────────────────────────────────────────
    if (!digitalRead(PIN_ENC_SW))
    {
        performFactoryResetAll(); // Erases NVS and restarts
    }

    // ──────────────────────────────────────────────
    // 6️⃣ Start WiFi configuration / captive portal
    // ──────────────────────────────────────────────
    HB9IIUPortal::begin("contest");

    // ──────────────────────────────────────────────
    // 7️⃣ Connected → normal operational mode
    // ──────────────────────────────────────────────
    if (HB9IIUPortal::isConnected())
    {
        // Retrieve stored callsign / panel ID
        gPanelIdStr = getStoredCallsign();
        PANEL_ID = gPanelIdStr.c_str();

        Serial.println(F("──────────────────────────────────────────────"));
        Serial.println(F("[APP] 📡 WiFi connected successfully"));
        Serial.printf("   ↳ Remote Panel ID  : %s\n", PANEL_ID);
        Serial.printf("   ↳ Local IP Address : %s\n",
                      WiFi.localIP().toString().c_str());
        Serial.println(F("──────────────────────────────────────────────\n"));

        // Show main remote panel background
        displayImageOnTFT("club.png");
        drawRemoteStationLabel();

        // Network services
        mqttSetup(); // Secure MQTT client
        publishAntennaState("boot");
        setupElegantOTA(); // OTA web server

        // Time synchronization (SNTP)
        waitForTimeVerbose();
        delay(1000);
        printTimes();

        // Initial UI state
        displayImageOnTFT("greatcircleMap.png");
        drawLocalAndUTCTime(240, 10);
        initAntennaDial();
        drawModeIndicator(true); // FORCE
        loadPresetsFromNVS();

        Serial.println(F("✅ Setup complete.\n"));
    }

    // ──────────────────────────────────────────────
    // 8️⃣ Not connected → AP mode / connecting
    // ──────────────────────────────────────────────
    else
    {
        wifi_mode_t mode = WiFi.getMode();
        wl_status_t status = WiFi.status();

        Serial.println(F("──────────────────────────────────────────────"));
        Serial.println(F("[APP] ⚠️  WiFi not connected at setup stage"));
        Serial.printf("   ↳ Current WiFi mode : %s\n",
                      (mode == WIFI_AP)       ? "Access Point (AP)"
                      : (mode == WIFI_STA)    ? "Station (Client)"
                      : (mode == WIFI_AP_STA) ? "AP + STA (mixed)"
                                              : "WiFi OFF");

        Serial.printf("   ↳ WiFi status       : %s\n",
                      (status == WL_NO_SSID_AVAIL)    ? "No SSID available"
                      : (status == WL_CONNECT_FAILED) ? "Connection failed"
                      : (status == WL_DISCONNECTED)   ? "Disconnected"
                      : (status == WL_IDLE_STATUS)    ? "Idle (trying...)"
                      : (status == WL_CONNECTED)      ? "Connected (unexpected)"
                                                      : "Unknown");
        Serial.println();

        Serial.println(F("   ↳ AP / portal mode active"));
        Serial.println(F("   ↳ QR code and setup UI handled by HB9IIUPortal"));
        Serial.println(F("──────────────────────────────────────────────\n"));

        // Nothing else to do here:
        // portal owns the TFT and user interaction until connected.
    }

    // KEYPAD NAV BUTTON
    //  --- Keypad / PCF page ---
    //  ---- I2C + PCF8574 init (for KEYPAD page) ----
    Wire.begin(PIN_SDA, PIN_SCL);

    if (!pcf.begin())
    {
        Serial.println("[PCF] begin() failed");
    }
    else if (!pcf.isConnected())
    {
        Serial.printf("[PCF] not connected at 0x%02X\n", PCF_ADDR);
    }
    else
    {
        Serial.printf("[PCF] OK at 0x%02X\n", PCF_ADDR);
    }

    // Prepare keypad layout once (positions, labels)
    layoutUI_480x320();

    // Make outputs match initial UI state (all OFF unless you change b[].active somewhere)
    pcfApplyFromButtons();

    drawKeypadNavButton(true);
    drawTRX_SDRButton(true);
}

// ============================================================================
//                                    LOOP
// ============================================================================
void loop()
{
    // ──────────────────────────────────────────────
    // 0) User idle detection
    // ──────────────────────────────────────────────
    bool userIdle = (millis() - lastUserInteractionMs) > USER_IDLE_MS;

    // ──────────────────────────────────────────────
    // 1) Portal servicing (idle-only)
    // ──────────────────────────────────────────────
    if (userIdle)
    {
        HB9IIUPortal::loop();
    }

    // ──────────────────────────────────────────────
    // 2) Connected operation
    // ──────────────────────────────────────────────
    if (HB9IIUPortal::isConnected())
    {
        // OTA servicing (always)
        otaServer.handleClient();
        ElegantOTA.loop();

        // During OTA, suspend everything else
        if (otaActive)
        {
            delay(5);
            return;
        }

        // MQTT keep-alive
        mqttClient.loop();

        // ──────────────────────────────────────────────
        // KEYPAD view owns touch handling (must run every loop)
        // ──────────────────────────────────────────────
        if (gView == VIEW_KEYPAD)
        {
            keypadTick();                // handles toggles + PCF + Return button
            updateTimeIfMinuteChanged(); // optional, but harmless
            return;                      // do NOT run antenna UI while keypad is active
        }

        // ──────────────────────────────────────────────
        // 2a) High-priority physical inputs
        //     (disable antenna UI inputs while KEYPAD view is active)
        // ──────────────────────────────────────────────
        if (gView != VIEW_KEYPAD)
        {
            updateModeSelectButton();
            updateExtraButtons();
            updateEncoder(); // only ONCE per loop
        }

        // ──────────────────────────────────────────
        // Antenna pulse animation (dial view only)
        // ──────────────────────────────────────────
        if (!awaitingClubConfirm &&
            (gView == VIEW_DIAL) &&
            selectedAntenna >= ANTENNA_MIN &&
            selectedAntenna <= ANTENNA_MAX)
        {
            unsigned long now = millis();

            if (now - lastPulseUpdate >= PULSE_INTERVAL_MS)
            {
                lastPulseUpdate = now;
                pulseBrightness += pulseDirection;

                if (pulseBrightness <= 100 || pulseBrightness >= 255)
                {
                    pulseDirection = -pulseDirection;
                    pulseBrightness = constrain(pulseBrightness, 100, 255);
                }

                uint16_t color = tft.color565(pulseBrightness, 0, 0); // RED

                tft.drawCircle(dotX[selectedAntenna], dotY[selectedAntenna],
                               DIAL_DOT_RADIUS + 1, TFT_WHITE);
                drawAntennaDot(selectedAntenna, color);
            }
        }

        // ──────────────────────────────────────────
        // WiFi RSSI indicator (idle-only)
        // ──────────────────────────────────────────
        static long lastRssi = 0;
        long rssi = WiFi.RSSI();
        if (userIdle && abs(rssi - lastRssi) > 2)
        {
            drawWiFiIndicator();
            lastRssi = rssi;
        }

        // ──────────────────────────────────────────
        // MQTT status indicator (idle-only)
        // ──────────────────────────────────────────
        static unsigned long lastMQTTDraw = 0;
        if (userIdle && millis() - lastMQTTDraw > 100)
        {
            lastMQTTDraw = millis();
            drawMQTTIndicator();
        }

        // ──────────────────────────────────────────
        // MQTT auto-reconnect watchdog (idle-only)
        // ──────────────────────────────────────────
        static unsigned long lastMQTTCheck = 0;
        const unsigned long MQTT_RECHECK_MS = 10000;

        if (userIdle && millis() - lastMQTTCheck >= MQTT_RECHECK_MS)
        {
            lastMQTTCheck = millis();

            if (!mqttEnsureConnected())
                Serial.println(F("[MQTT] Reconnect attempt failed"));
            else
                printMQTTConnectionOK();
        }

        // ──────────────────────────────────────────
        // Touchscreen polling
        // ──────────────────────────────────────────
        static unsigned long lastTouchCheck = 0;
        if (millis() - lastTouchCheck > 100)
        {
            lastTouchCheck = millis();

            uint16_t x, y;
            if (tft.getTouch(&x, &y))
            {
                lastUserInteractionMs = millis();

                // ----------------------------
                // If we are on KEYPAD page:
                // only handle keypad interactions here
                // ----------------------------
                // TRX/SDR toggle button (DIAL only)
                // TRX/SDR toggle button (DIAL only) + extra debounce
                if (hitTRX_SDRButton(x, y))
                {
                    unsigned long now = millis();

                    // ignore if pressed again too soon
                    if (now - lastTRXSDRTouchMs < TRX_SDR_DEBOUNCE_MS)
                        return;

                    lastTRXSDRTouchMs = now;

                    onTRX_SDRButtonPressed();
                    return;
                }

                // ----------------------------
                // From DIAL/MAP: open keypad if nav hit
                // ----------------------------
                if (hitKeypadNavButton(x, y))
                {
                    enterKeypadView();
                    return;
                }

                // ----------------------------
                // Otherwise: your original behavior
                // toggle MAP <-> DIAL
                // ----------------------------
                gView = (gView == VIEW_MAP) ? VIEW_DIAL : VIEW_MAP;

                if (gView != VIEW_MAP)
                {
                    displayImageOnTFT("greatcircleMap.png");
                    initAntennaDial();
                    drawModeIndicator(true);
                    updateDynamicCornerLabels(true);
                    drawLocalAndUTCTime(240, 10);
                    drawKeypadNavButton(true);
                    drawTRX_SDRButton(true);
                }
                else
                {
                    tft.fillScreen(TFT_BLACK);
                    displayImageOnTFT("equirectangularMap.png");
                    float az = dotAzimuthDeg[preSelectedAntenna];
                    plotGreatCircle(HOME_LAT_DEG, HOME_LON_DEG, az, TFT_GOLD, 2);
                    updateMapBottomLabel();
                    drawWiFiIndicator();
                    drawKeypadNavButton(true);
                }

                return;
            }
        }

        // ──────────────────────────────────────────────
        // Time update (minute resolution)
        // ──────────────────────────────────────────────
        updateTimeIfMinuteChanged();
    }
    else
    {
        // ──────────────────────────────────────────────
        // 3) Not connected: portal waiting
        // ──────────────────────────────────────────────
        static unsigned long lastPortalMsg = 0;
        if (millis() - lastPortalMsg > 5000)
        {
            lastPortalMsg = millis();
            Serial.println(F("[PORTAL] Waiting for WiFi configuration..."));
        }

        // If you still want buttons usable while portal is showing,
        // you can keep these uncommented. Otherwise leave off.
        // updateModeSelectButton();
        // updateExtraButtons();
        // updateEncoder();
    }
}

// ============================================================================
//                            WIFI / MQTT HELPERS
// ============================================================================

void mqttSetup()
{
    Serial.println(F("[MQTT] Setting up secure client ..."));
    mqttSecureClient.setInsecure();
    mqttSecureClient.setTimeout(15000);
    mqttClient.setServer(MQTT_HOST, MQTT_PORT);
    mqttClient.setCallback(mqttCallback);
    mqttEnsureConnected();
}

bool mqttEnsureConnected()
{
    if (WiFi.status() != WL_CONNECTED)
        return false;

    if (mqttClient.connected())
        return true;

    Serial.println(F("[MQTT] (Re)connecting to broker..."));

    String clientId = String("cyd-club-") + String((uint32_t)ESP.getEfuseMac(), HEX);

    if (mqttClient.connect(clientId.c_str(), MQTT_USER, MQTT_PASSWD))
    {
        Serial.println(F("[MQTT] Connected to HiveMQ Cloud"));

        // ✅ CLUB MODE: subscribe to antenna commands
        if (mqttClient.subscribe(MQTT_TOPIC_CMD))
        {
            Serial.print(F("[MQTT] Subscribed to "));
            Serial.println(MQTT_TOPIC_CMD);
        }
        else
        {
            Serial.println(F("[MQTT] Failed to subscribe to antenna/cmd"));
        }

        return true;
    }
    else
    {
        Serial.print(F("[MQTT] Connection FAILED, rc="));
        Serial.println(mqttClient.state());
        return false;
    }
}

void publishAntennaState(const char *reason)
{
    if (!mqttEnsureConnected())
    {
        Serial.println(F("[CLUB] Cannot publish state: MQTT not connected"));
        return;
    }

    char payload[128];
    snprintf(payload, sizeof(payload),
             "{\"selected\":%u,\"pre\":%u,\"source\":\"CLUB\",\"reason\":\"%s\"}",
             selectedAntenna,
             selectedAntenna,
             reason);

    bool ok = mqttClient.publish(MQTT_TOPIC_STATE, payload, true); // retained

    Serial.print(F("[CLUB] STATE -> "));
    Serial.print(payload);
    Serial.print(F("  (retained="));
    Serial.print(ok ? F("OK") : F("FAIL"));
    Serial.println(F(")"));
}

// Incoming MQTT messages (state + heartbeat from club)
void mqttCallback(char *topic, byte *payload, unsigned int length)
{
    // CLUB MODE: receive antenna commands
    if (strcmp(topic, MQTT_TOPIC_CMD) != 0)
        return;

    char buf[128];
    if (length >= sizeof(buf))
        length = sizeof(buf) - 1;

    memcpy(buf, payload, length);
    buf[length] = '\0';

    int req = -1;
    if (sscanf(buf, "{\"select\":%d", &req) == 1)
    {
        if (req >= ANTENNA_MIN && req <= ANTENNA_MAX)
        {
            // ── REMOTE interaction detected ───────────────────
            lastRemoteInteractionMs = millis();

            Serial.printf("[CLUB] REMOTE interaction: SELECT %d\n", req);

            // Authoritative state update
            selectedAntenna = req;
            preSelectedAntenna = req;

            updateDialColors();
            updateDynamicCornerLabels();

            // Publish authoritative state (retained)
            publishAntennaState("mqtt");
        }
        else
        {
            Serial.printf("[CLUB] Invalid antenna index: %d\n", req);
        }
    }
    else
    {
        Serial.print(F("[CLUB] Invalid MQTT payload: "));
        Serial.println(buf);
    }
}

// Publish a SELECT command to the club
// Called on every encoder detent (immediate selection)
void publishSelectCommand()
{
    Serial.println(F("[REMOTE] publishSelectCommand() called"));

    if (!mqttEnsureConnected())
    {
        Serial.println(F("[REMOTE] mqttEnsureConnected() FAILED, not publishing."));
        return;
    }

    char payload[80];
    snprintf(payload, sizeof(payload),
             "{\"select\":%u,\"source\":\"%s\"}",
             selectedAntenna, PANEL_ID);

    Serial.print(F("[REMOTE] SELECT -> "));
    Serial.print(MQTT_TOPIC_CMD);
    Serial.print(F(" : "));
    Serial.println(payload);

    bool ok = mqttClient.publish(MQTT_TOPIC_CMD, payload);
    Serial.print(F("[REMOTE] mqttClient.publish(SELECT) returned: "));
    Serial.println(ok ? F("true") : F("false"));
}

// ============================================================================
//                            SYSTEM INIT HELPERS
// ============================================================================

void initAntennaDial()
{
    Serial.println(F("[INIT] Antenna dial"));

    loadDotConfig();
    ANTENNA_MAX = numDots;

    updateAllDotPositions();
    drawDialBase();

    // IMPORTANT: do NOT reset selectedAntenna / preSelectedAntenna here.
    // We want to keep whatever state we currently have from CLUB/REMOTE.
    updateDialColors();

    updateDynamicCornerLabels();
}

void initEncoderPins()
{
    Serial.println();
    Serial.println(F("───────────────────────────────────────────────────────────────────────────────"));
    pinMode(PIN_ENC_DT, INPUT_PULLUP);  // Encoder A
    pinMode(PIN_ENC_CLK, INPUT_PULLUP); // Encoder B
    pinMode(PIN_ENC_SW, INPUT_PULLUP);  // Encoder button

    // --- Capture initial electrical state ---
    int dt = digitalRead(PIN_ENC_DT);
    int clk = digitalRead(PIN_ENC_CLK);
    int sw = digitalRead(PIN_ENC_SW);
    lastState = (dt << 1) | clk;

    // --- Explain each line clearly ---
    Serial.println(F("GPIO configuration and idle signal state:"));
    Serial.printf("   ↳ DT  pin : %-2d   (INPUT)  level=%d  → signal A, %s\n",
                  PIN_ENC_DT, dt, dt ? "idle HIGH (open contact)" : "active LOW (closed to GND)");
    Serial.printf("   ↳ CLK pin : %-2d   (INPUT)  level=%d  → signal B, %s\n",
                  PIN_ENC_CLK, clk, clk ? "idle HIGH (open contact)" : "active LOW (closed to GND)");
    Serial.printf("   ↳ SW  pin : %-2d   (INPUT_PULLUP) level=%d  → push-button, %s\n",
                  PIN_ENC_SW, sw, sw ? "released (HIGH)" : "pressed (LOW)");

    Serial.println();
    Serial.printf("   ↳ Initial encoder state: 0b%02d (DT=%d, CLK=%d)\n", lastState, dt, clk);
    Serial.println();
    Serial.println(F("   ✅ Encoder GPIOs all configured as inputs."));
    Serial.println(F("   Encoder lines read HIGH → mechanical contacts are open (idle state)."));
    Serial.println(F("───────────────────────────────────────────────────────────────────────────────"));
    Serial.println();
}

// ============================================================================
//                             ANTENNA DIAL HELPERS
// ============================================================================

void loadDotConfig()
{
    numDots = 11;

    dotAzimuthDeg[1] = 0.0f;
    dotAzimuthDeg[2] = 20.0f;
    dotAzimuthDeg[3] = 45.0f;
    dotAzimuthDeg[4] = 60.0f;
    dotAzimuthDeg[5] = 90.0f;
    dotAzimuthDeg[6] = 135.0f;
    dotAzimuthDeg[7] = 180.0f;
    dotAzimuthDeg[8] = 225.0f;
    dotAzimuthDeg[9] = 275.0f;
    dotAzimuthDeg[10] = 310.0f;
    dotAzimuthDeg[11] = 330.0f;
}

void updateAllDotPositions()
{
    int16_t cx = tft.width() / 2;
    int16_t cy = tft.height() / 2;

    for (uint8_t i = 1; i <= numDots; i++)
    {
        float rad = dotAzimuthDeg[i] * PI / 180.0f;
        dotX[i] = cx + (int16_t)round(DIAL_RING_RADIUS * sin(rad));
        dotY[i] = cy - (int16_t)round(DIAL_RING_RADIUS * cos(rad));
    }
}

void setDotAzimuth(uint8_t index, float azimuthDeg)
{
    if (index < 1 || index > numDots)
        return;

    dotAzimuthDeg[index] = azimuthDeg;

    int16_t cx = tft.width() / 2;
    int16_t cy = tft.height() / 2;
    float rad = azimuthDeg * PI / 180.0f;

    dotX[index] = cx + (int16_t)round(DIAL_RING_RADIUS * sin(rad));
    dotY[index] = cy - (int16_t)round(DIAL_RING_RADIUS * cos(rad));
}

void drawAntennaDot(uint8_t index, uint16_t color)
{
    if (index < 1 || index > numDots)
        return;

    tft.fillCircle(dotX[index], dotY[index], DIAL_DOT_RADIUS, color);
    tft.drawCircle(dotX[index], dotY[index], DIAL_DOT_RADIUS + 1, TFT_WHITE);
}

void drawDialBase()
{
    for (uint8_t i = 1; i <= numDots; i++)
        drawAntennaDot(i, TftGrey);
}

void updateDialColors()
{
    for (uint8_t i = 1; i <= numDots; i++)
    {
        uint16_t color = TftGrey;

        if (i == selectedAntenna)
            color = TftGreen;

        if ((i == preSelectedAntenna) && (preSelectedAntenna != selectedAntenna))
            color = TftRed;

        drawAntennaDot(i, color);
    }
}

// ============================================================================
//                           ROTARY ENCODER LOGIC (FINAL)
// ============================================================================
//
// Behaviour model (CLUB controller):
//
//   • Encoder rotation does NOT immediately switch antennas
//   • Rotation enters a PREVIEW phase:
//       - Selected antenna stays unchanged
//       - Preview antenna is shown in YELLOW
//       - Current active antenna remains GREEN
//
//   • When the user STOPS rotating for PREVIEW_SETTLE_MS:
//       - Preview antenna is COMMITTED
//       - switchAntenna() is called ONCE
//       - MQTT authoritative state is published (retained)
//
// Safety / UX guarantees:
//
//   • No hardware chatter (DTMF / relays triggered once per selection)
//   • Fast rotation is safe — only the final position matters
//   • Deterministic behaviour (no speed-based heuristics)
//
// Special case:
//
//   • If the great-circle map is displayed:
//       - The FIRST encoder detent exits the map
//       - No antenna change occurs
//       - No MQTT traffic is generated
//
// This function is called at high frequency from loop() and must remain
// lightweight and deterministic.
// ============================================================================

void updateEncoder()
{
    int dt = digitalRead(PIN_ENC_DT);
    int clk = digitalRead(PIN_ENC_CLK);
    uint8_t currentState = (dt << 1) | clk;

    uint8_t index = (lastState << 2) | currentState;
    int8_t movement = encTable[index];

    bool detent = false;

    if (movement != 0)
    {
        encoderAccum += movement;
        lastState = currentState;

        if (encoderAccum >= STEPS_PER_NOTCH)
        {
            encoderAccum = 0;
            detent = true;

            // Exit map on first detent (unchanged)
            if (gView == VIEW_MAP)
            {
                gView = VIEW_DIAL;
                displayImageOnTFT("greatcircleMap.png");
                initAntennaDial();
                drawModeIndicator(true); // FORCE
                updateDynamicCornerLabels(true);
                drawLocalAndUTCTime(240, 10);
                return;
            }

            // Start preview session if not active
            if (previewAntenna == 0)
                previewAntenna = selectedAntenna;

            // CW
            previewAntenna =
                (previewAntenna >= ANTENNA_MAX) ? ANTENNA_MIN : (previewAntenna + 1);
        }
        else if (encoderAccum <= -STEPS_PER_NOTCH)
        {
            encoderAccum = 0;
            detent = true;

            // Exit map on first detent (unchanged)
            if (gView == VIEW_MAP)
            {
                gView = VIEW_DIAL;
                displayImageOnTFT("greatcircleMap.png");
                initAntennaDial();
                drawModeIndicator(true); // FORCE
                updateDynamicCornerLabels(true);
                drawLocalAndUTCTime(240, 10);
                return;
            }

            // Start preview session if not active
            if (previewAntenna == 0)
                previewAntenna = selectedAntenna;

            // CCW
            previewAntenna =
                (previewAntenna <= ANTENNA_MIN) ? ANTENNA_MAX : (previewAntenna - 1);
        }
    }
    else
    {
        lastState = currentState;
    }

    // ──────────────────────────────────────────────
    // Preview redraw
    // ──────────────────────────────────────────────
    if (detent)
    {
        lastUserInteractionMs = millis();
        lastEncoderActivityMs = millis();

        for (uint8_t i = 1; i <= ANTENNA_MAX; i++)
        {
            if (i == selectedAntenna)
                drawAntennaDot(i, TftGreen);
            else if (i == previewAntenna)
                drawAntennaDot(i, TftYellow);
            else
                drawAntennaDot(i, TftGrey);
        }

        Serial.printf("[UI ] Preview antenna %u\n", previewAntenna);
    }

    // ──────────────────────────────────────────────
    // Commit after settle time
    // ──────────────────────────────────────────────
    if (previewAntenna != 0 &&
        (millis() - lastEncoderActivityMs) > PREVIEW_SETTLE_MS)
    {
        if (previewAntenna != selectedAntenna)
        {
            Serial.printf("[CLUB] Commit antenna %u\n", previewAntenna);

            if (switchAntenna(previewAntenna))
            {
                selectedAntenna = previewAntenna;
                preSelectedAntenna = selectedAntenna;

                updateDialColors();
                updateDynamicCornerLabels();

                publishAntennaState("encoder");
            }
        }

        // End preview session
        previewAntenna = 0;
    }
}

// Button is currently optional; if you want the button
// to also send a SELECT with the current selectedAntenna,
// just keep this function and call updateButton() from loop().
void updateButton()
{
    static int lastButtonSample = HIGH;
    static int stableState = HIGH;

    int reading = digitalRead(PIN_ENC_SW); // HIGH = released, LOW = pressed

    if (reading != lastButtonSample)
    {
        lastDebounceTime = millis();
        lastButtonSample = reading;
    }

    if ((millis() - lastDebounceTime) > debounceDelayMs)
    {
        if (reading != stableState)
        {
            stableState = reading;

            if (stableState == LOW)
            {
                Serial.print(F("[REMOTE] BUTTON: request select "));
                Serial.println(selectedAntenna);

                // Already selected locally; just confirm to CLUB if desired
                publishSelectCommand();
            }
        }
    }
}

// ============================================================================
//                           CORNER TEXT / OVERLAY
// ============================================================================
void updateDynamicCornerLabels(bool force)
{
    static uint8_t lastAntenna = 255;
    static int lastAzimuth = -999;
    if (force)
    {
        lastAntenna = 255;
        lastAzimuth = -999;
    }
    int16_t w = tft.width();

    // --- Retrieve current values ---
    uint8_t ant = preSelectedAntenna;
    int az = round(dotAzimuthDeg[ant]);

    // --- Label font ---
    tft.setTextFont(2);
    tft.setTextSize(1);
    tft.setTextColor(TFT_WHITE, TFT_BLACK);
    tft.setTextColor(VERY_LIGHT_GREY, TFT_BLACK);
    tft.setFreeFont(&RobotoMono_Light8pt7b);

    // --- Left side (Antenna) ---
    tft.setTextDatum(TL_DATUM);

    tft.drawString("Antenna", 6, 1);

    // --- Right side (Azimuth) ---
    tft.setTextDatum(TR_DATUM);
    tft.drawString("Azimuth", w - 6, 2);

    // --- Value font ---
    tft.setTextFont(4);
    tft.setTextSize(1);

    // --- Antenna value (left) ---
    char bufAnt[8];
    snprintf(bufAnt, sizeof(bufAnt), "%u", ant);

    if (ant != lastAntenna)
    {
        // Use your FreeFont for BOTH erase + redraw
        tft.setFreeFont(&RobotoMono_Bold26pt7b);
        tft.setTextDatum(TR_DATUM);

        // erase previous value (draw old one in black)
        char bufOld[8];
        snprintf(bufOld, sizeof(bufOld), "%u", lastAntenna);
        tft.setTextColor(TFT_BLACK, TFT_BLACK);
        tft.drawString(bufOld, 50, 24);

        // draw new one
        tft.setTextColor(VERY_LIGHT_GREY, TFT_BLACK);
        tft.drawString(bufAnt, 50, 24);

        lastAntenna = ant;
    }

    // --- Azimuth value (right) ---
    char bufAz[16];
    snprintf(bufAz, sizeof(bufAz), "%d%c", az, (char)176);

    if (az != lastAzimuth)
    {
        tft.setFreeFont(&RobotoMono_Bold26pt7b);
        tft.setTextDatum(TR_DATUM);

        // erase previous value
        char bufOld[16];
        snprintf(bufOld, sizeof(bufOld), "%d%c", lastAzimuth, (char)176);
        tft.setTextColor(TFT_BLACK, TFT_BLACK);
        tft.drawString(bufOld, w - 10, 24);

        // draw new value
        tft.setTextColor(VERY_LIGHT_GREY, TFT_BLACK);
        tft.drawString(bufAz, w - 10, 24);

        lastAzimuth = az;

        int r0 = 3; // inner radius

        for (uint8_t i = 0; i < 3; i++)
        {
            tft.drawCircle(w - 7, 26, r0 + i, VERY_LIGHT_GREY);
        }
    }
}

String getStoredCallsign()
{
    String cs;

    if (preferences.begin("config", true)) // read-only
    {
        cs = preferences.getString("callsign", "");
        preferences.end();
    }

    return cs;
}

// -----------------------------------------------------------------------------
//                         GREAT-CIRCLE / MAP HELPERS
// -----------------------------------------------------------------------------

// Convert latitude/longitude (deg) to TFT pixel coordinates (x,y)
void latLonToXY(float lat_deg, float lon_deg, int16_t &x, int16_t &y)
{
    // Clamp latitude just in case
    if (lat_deg > 90.0f)
        lat_deg = 90.0f;
    if (lat_deg < -90.0f)
        lat_deg = -90.0f;

    // Normalize longitude to [-180, +180]
    while (lon_deg < -180.0f)
        lon_deg += 360.0f;
    while (lon_deg > 180.0f)
        lon_deg -= 360.0f;

    float xf = (lon_deg + 180.0f) / 360.0f * MAP_W;
    float yf = (90.0f - lat_deg) / 180.0f * MAP_H;

    x = MAP_X0 + (int16_t)roundf(xf);
    y = MAP_Y0 + (int16_t)roundf(yf);
}

// Plot great-circle path from home toward a given azimuth
void plotGreatCircle(float homeLat_deg, float homeLon_deg,
                     float azimuth_deg,
                     uint16_t color, uint8_t diameter)
{
    if (diameter == 0)
        diameter = 1;
    uint8_t radius = diameter / 2;

    // Convert to radians
    float lat1 = homeLat_deg * PI / 180.0f;
    float lon1 = homeLon_deg * PI / 180.0f;
    float brg = azimuth_deg * PI / 180.0f;

    float sinLat1 = sinf(lat1);
    float cosLat1 = cosf(lat1);
    float sinBrg = sinf(brg);
    float cosBrg = cosf(brg);

    Serial.printf("Plotting great-circle: lat=%.4f lon=%.4f brg=%.2f°\n",
                  homeLat_deg, homeLon_deg, azimuth_deg);

    float prevLat = homeLat_deg;
    bool goingNorth = (azimuth_deg < 90.0f || azimuth_deg > 270.0f);

    for (float theta_deg = 0.0f; theta_deg <= 180.0f; theta_deg += 0.5f)
    {
        float d = theta_deg * PI / 180.0f;
        float sinD = sinf(d);
        float cosD = cosf(d);

        // Forward geodesic
        float lat2 = asinf(sinLat1 * cosD + cosLat1 * sinD * cosBrg);
        lat2 = constrain(lat2, -PI / 2.0f, PI / 2.0f);

        float lon2;
        if (fabsf(sinBrg) < 1e-6f)
        {
            lon2 = lon1; // same meridian for due N/S
        }
        else
        {
            float yTerm = sinBrg * sinD * cosLat1;
            float xTerm = cosD - sinLat1 * sinf(lat2);
            lon2 = lon1 + atan2f(yTerm, xTerm);
            if (lon2 < -PI)
                lon2 += 2.0f * PI;
            else if (lon2 > PI)
                lon2 -= 2.0f * PI;
        }

        float lat2_deg = lat2 * 180.0f / PI;
        float lon2_deg = lon2 * 180.0f / PI;

        int16_t x, y;
        latLonToXY(lat2_deg, lon2_deg, x, y);

        if (x >= 0 && x < tft.width() && y >= 0 && y < tft.height())
            tft.fillCircle(x, y, radius, color);

        // --- Stop when latitude reverses (only for due N/S) ---
        if ((fabsf(azimuth_deg) < 1.0f || fabsf(azimuth_deg - 180.0f) < 1.0f))
        {
            if ((goingNorth && lat2_deg < prevLat) ||
                (!goingNorth && lat2_deg > prevLat))
            {
                break; // stop when motion reverses after pole
            }
            prevLat = lat2_deg;
        }

        // generic pole stop for all bearings
        if (fabsf(lat2_deg) >= 89.9f)
            break;
    }
}

// Bottom label "Antenna N (xxx deg.)" on map
void updateMapBottomLabel()
{
    float az = dotAzimuthDeg[preSelectedAntenna];

    char buf[32];
    snprintf(buf, sizeof(buf),
             "Antenna %u (%.0f deg.)",
             preSelectedAntenna, az);

    tft.setTextFont(4);
    tft.setTextSize(1);
    tft.setTextColor(TFT_WHITE, TFT_BLACK);
    tft.setTextDatum(TC_DATUM);

    // Clear band at bottom for label
    tft.fillRect(0, 280, tft.width(), 40, TFT_BLACK);
    tft.drawString(buf, tft.width() / 2, 295);
}

void drawRemoteStationLabel()
{
    char line[40];
    snprintf(line, sizeof(line), "Station %s", PANEL_ID);

    tft.setTextFont(4);
    tft.setTextSize(1);

    // ✅ Only one color argument → transparent background
    tft.setTextColor(TFT_WHITE);

    tft.setTextDatum(MC_DATUM);

    int16_t centerX = tft.width() / 2;
    int16_t centerY = 310;

    // ❌ Don’t clear with fillRect — keep the image underneath
    // tft.fillRect(0, 310, tft.width(), 40, TFT_BLACK);

    // ✅ Draw transparent text directly on the picture
    tft.drawString(line, centerX, centerY);
}

void performFactoryResetAll()
{
    int16_t w = tft.width();
    int16_t h = tft.height();

    Serial.println(F("[RESET] Performing factory reset: erasing ALL NVS (all Preferences)."));

    // Simple message on TFT (no dialog, just info)
    tft.fillScreen(TFT_BLACK);
    tft.setTextColor(TFT_WHITE, TFT_BLACK);
    tft.setTextFont(4);
    tft.setTextSize(1);
    tft.setTextDatum(MC_DATUM);
    tft.drawString("Factory Reset...", w / 2, h / 2 - 20);
    tft.drawString("Erasing User Configuration", w / 2, h / 2 + 20);

    // Erase the entire NVS partition: all namespaces, including "config",
    // WiFi credentials, and anything stored by HB9IIUPortal.
    esp_err_t err = nvs_flash_erase();
    if (err == ESP_OK)
    {
        Serial.println(F("[RESET] nvs_flash_erase() OK."));
    }
    else
    {
        Serial.print(F("[RESET] nvs_flash_erase() ERROR: "));
        Serial.println((int)err);
    }

    // Re-init NVS so the next boot has a clean state
    err = nvs_flash_init();
    if (err == ESP_OK)
    {
        Serial.println(F("[RESET] nvs_flash_init() OK after erase."));
    }
    else
    {
        Serial.print(F("[RESET] nvs_flash_init() ERROR: "));
        Serial.println((int)err);
    }

    delay(2000);
    tft.fillScreen(TFT_BLACK);
    tft.drawString("Restarting...", w / 2, h / 2);
    delay(2000);

    ESP.restart(); // does not return
}

void setupElegantOTA()
{
    // HB9IIUPortal already connected WiFi.

    otaServer.on("/", []()
                 {
                    Serial.println(F("[OTA] Redirecting to /update"));
                     otaActive = true; // OTA upload really starts HERE

                     otaServer.sendHeader("Location", "/update", true);
                     otaServer.send(302, "text/plain", ""); });
    otaServer.on(
        "/update",
        HTTP_POST,
        []() {},              // final response handled by ElegantOTA
        []() {                // upload handler
            otaActive = true; // OTA upload really starts HERE
        });
    ElegantOTA.begin(&otaServer); // inject /update routes
    otaServer.begin();

    Serial.println(F("[OTA] ElegantOTA started on http://contest.local/update"));
}
void checkAndApplyTFTCalibrationData(bool recalibrate)
{
    Serial.println(F("───────────────────────────────────────────────────────────────────────────────"));
    Serial.println(F("[INIT] 🖥️  TFT Touch Calibration Check"));
    Serial.println(F("───────────────────────────────────────────────────────────────────────────────"));

    if (recalibrate)
    {
        Serial.println(F("↪ Forced recalibration requested — launching calibration wizard..."));
        calibrateTFTscreen();
        return;
    }

    uint16_t calibrationData[5];
    bool dataValid = true;

    Serial.println(F("Reading stored calibration data from NVS namespace: 'TFT'"));
    preferences.begin("TFT", true); // read-only mode

    for (int i = 0; i < 5; i++)
    {
        calibrationData[i] = preferences.getUInt(("calib" + String(i)).c_str(), 0xFFFF);
        if (calibrationData[i] == 0xFFFF)
        {
            dataValid = false;
            Serial.printf("   ⚠️  calib%d = 0xFFFF → missing or invalid\n", i);
        }
        else
        {
            Serial.printf("   ✓ calib%d = %u\n", i, calibrationData[i]);
        }
    }
    preferences.end();

    if (dataValid)
    {
        tft.setTouch(calibrationData);
        Serial.println();
        Serial.println(F("✅ TFT touch calibration successfully retrieved and applied."));
        Serial.println(F("───────────────────────────────────────────────────────────────────────────────"));
    }
    else
    {
        Serial.println();
        Serial.println(F("❌ Calibration data invalid or incomplete."));
        Serial.println(F("↪ Starting full recalibration procedure..."));
        Serial.println(F("───────────────────────────────────────────────────────────────────────────────"));
        digitalWrite(TFT_BLP, HIGH);
        calibrateTFTscreen();
    }

    Serial.println();
}

void calibrateTFTscreen()
{
    uint16_t calibrationData[5];

    // Display recalibration message
    tft.fillScreen(TFT_BLACK);             // Clear screen
    tft.setTextColor(TFT_BLACK, TFT_GOLD); // Set text color (black on gold)
    tft.setFreeFont(&FreeSansBold12pt7b);  // Use custom free font
    tft.setCursor(10, 22);
    tft.fillRect(0, 0, 480, 30, TFT_GOLD);
    tft.print("   TFT TOUCHSCREEN CALIBRATION");
    tft.setTextColor(TFT_WHITE, TFT_BLACK);

    tft.setFreeFont(&FreeSans12pt7b);

    String instructions[] = {
        "Welcome to the initial touchscreen calibration.",
        "This procedure will only be required once.",
        "On the next screen you will see arrows",
        "appearing one after the other at each corner.",
        "Just tap them until completion.",
        "",
        "Tap anywhere on the screen to begin"};

    int16_t yPos = 100;

    for (String line : instructions)
    {
        int16_t xPos = (tft.width() - tft.textWidth(line)) / 2;
        tft.setCursor(xPos, yPos);
        tft.print(line);
        yPos += tft.fontHeight();
    }

    tft.setTextColor(TFT_GREEN, TFT_BLACK);
    tft.setCursor((tft.width() - tft.textWidth(instructions[6])) / 2, yPos - tft.fontHeight());
    tft.print(instructions[6]);

    while (true)
    {
        uint16_t x, y;
        if (tft.getTouch(&x, &y))
        {
            break;
        }
    }

    tft.fillScreen(TFT_BLACK);

    tft.calibrateTouch(calibrationData, TFT_GREEN, TFT_BLACK, 12);

    preferences.begin("TFT", false);
    for (int i = 0; i < 5; i++)
    {
        preferences.putUInt(("calib" + String(i)).c_str(), calibrationData[i]);
    }
    preferences.end();

    // Test calibration with dynamic feedback
    tft.fillScreen(TFT_BLACK);
    uint16_t x, y;
    int16_t lastX = -1, lastY = -1;
    String lastResult = "";

    tft.setTextColor(TFT_WHITE, TFT_BLACK);
    tft.setTextFont(4);
    String text = "Tap anywhere to test";
    tft.setCursor((tft.width() - tft.textWidth(text)) / 2, 8);
    tft.print(text);

    text = "Click Here to Exit";
    int16_t btn_w = tft.textWidth(text) + 20;
    int16_t btn_h = tft.fontHeight() + 12;
    int16_t btn_x = (tft.width() - btn_w) / 2;
    int16_t btn_y = 280;
    int16_t btn_r = 10;

    tft.fillRoundRect(btn_x, btn_y, btn_w, btn_h, btn_r, TFT_BLUE);
    tft.drawRoundRect(btn_x, btn_y, btn_w, btn_h, btn_r, TFT_WHITE);
    tft.setTextColor(TFT_WHITE, TFT_BLUE);
    tft.setCursor((tft.width() - tft.textWidth(text)) / 2, btn_y + 10);
    tft.print(text);

    while (true)
    {
        if (tft.getTouch(&x, &y))
        {
            String result = "x=" + String(x) + "  y=" + String(y) + "  p=" + String(tft.getTouchRawZ());
            lastUserInteractionMs = millis();
            tft.setTextColor(TFT_BLACK, TFT_BLACK);
            tft.setCursor(lastX, lastY);
            tft.print(lastResult);

            int16_t textWidth = tft.textWidth(result);
            int16_t xPos = (tft.width() - textWidth) / 2;
            int16_t yPos = (tft.height() - tft.fontHeight()) / 2;

            tft.setTextColor(TFT_GREEN, TFT_BLACK);
            tft.setCursor(xPos, yPos);
            tft.print(result);

            lastX = xPos;
            lastY = yPos;
            lastResult = result;

            tft.fillCircle(x, y, 2, TFT_RED);

            if (x > btn_x && x < btn_x + btn_w && y > btn_y && y < btn_y + btn_h)
            {
                Serial.println("Exit Touched");
                break;
            }
        }
    }
    tft.setTextSize(2);
    tft.fillScreen(TFT_BLACK);
}

void testTouchscreen()
{
