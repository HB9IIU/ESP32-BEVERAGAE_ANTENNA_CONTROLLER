void printSystemInfo()
{
    Serial.println();
    Serial.println(F("───────────────────────────────────────────────────────────────────────────────"));
    Serial.println(F("[SYS] 📊  SYSTEM INFORMATION SUMMARY"));
    Serial.println(F("───────────────────────────────────────────────────────────────────────────────"));

    // --- Collect system metrics ---
    uint32_t flashSize = ESP.getFlashChipSize();
    uint32_t sketchUsed = ESP.getSketchSize();
    uint32_t sketchFree = ESP.getFreeSketchSpace();
    uint32_t heapFree = ESP.getFreeHeap();
    uint32_t heapTotal = ESP.getHeapSize();

#if CONFIG_SPIRAM_SUPPORT
    uint32_t psramFree = ESP.getFreePsram();
    uint32_t psramTotal = ESP.getPsramSize();
#endif

    // --- Compute percentages ---
    float flashUsedPct = (flashSize > 0) ? (100.0f * sketchUsed / flashSize) : 0.0f;
    float heapUsedPct = (heapTotal > 0) ? (100.0f * (heapTotal - heapFree) / heapTotal) : 0.0f;
#if CONFIG_SPIRAM_SUPPORT
    float psramUsedPct = (psramTotal > 0) ? (100.0f * (psramTotal - psramFree) / psramTotal) : 0.0f;
#endif

    // --- Determine status verdicts ---
    const char *flashVerdict = (flashUsedPct < 70.0f) ? "✅ OK" : (flashUsedPct < 85.0f) ? "⚠️  Moderate"
                                                                                         : "❌ HIGH";
    const char *heapVerdict = (heapUsedPct < 60.0f) ? "✅ OK" : (heapUsedPct < 80.0f) ? "⚠️  Moderate"
                                                                                      : "❌ LOW";
#if CONFIG_SPIRAM_SUPPORT
    const char *psramVerdict = (psramUsedPct < 70.0f) ? "✅ OK" : (psramUsedPct < 85.0f) ? "⚠️  Moderate"
                                                                                         : "❌ HIGH";
#endif

    // --- Print system info ---
    Serial.printf("ESP32 Chip Model     : %s\n", ESP.getChipModel());
    Serial.printf("CPU Cores            : %d\n", ESP.getChipCores());
    Serial.printf("CPU Frequency        : %d MHz\n", ESP.getCpuFreqMHz());
    Serial.printf("SDK Version          : %s\n", ESP.getSdkVersion());
    Serial.printf("Flash Chip Size      : %-10u bytes\n", flashSize);
    Serial.printf("Sketch Size (used)   : %-10u bytes  (%.1f%%)  → %s\n", sketchUsed, flashUsedPct, flashVerdict);
    Serial.printf("Free Sketch Space    : %-10u bytes\n", sketchFree);
    Serial.printf("Heap (free/total)    : %u / %u bytes  (used %.1f%%)  → %s\n",
                  heapFree, heapTotal, heapUsedPct, heapVerdict);
#if CONFIG_SPIRAM_SUPPORT
    Serial.printf("PSRAM (free/total)   : %u / %u bytes  (used %.1f%%)  → %s\n",
                  psramFree, psramTotal, psramUsedPct, psramVerdict);
#endif

    // --- Global verdict summary ---
    Serial.println(F("───────────────────────────────────────────────────────────────────────────────"));
    if (flashUsedPct < 70.0f && heapUsedPct < 60.0f)
        Serial.println(F("✅ System Health Summary : OK (Stable resources, OTA-capable)"));
    else if (flashUsedPct < 85.0f && heapUsedPct < 80.0f)
        Serial.println(F("⚠️  System Health Summary : Moderate (Monitor memory usage)"));
    else
        Serial.println(F("❌ System Health Summary : Critical (Risk of instability)"));
    Serial.println(F("───────────────────────────────────────────────────────────────────────────────"));
}
void mountAndListFiles()
{
    Serial.println(F("───────────────────────────────────────────────────────────────────────────────"));
    Serial.println(F("[INIT] 📂 LittleFS Mount & File Listing"));
    Serial.println(F("───────────────────────────────────────────────────────────────────────────────"));

    Serial.print(F("Mounting LittleFS... "));
    bool formatOnFail = true;
    if (!LittleFS.begin(formatOnFail))
    {
        Serial.println(F("❌ FAILED"));
        Serial.println(F("↪ LittleFS could not be mounted."));
        Serial.println(F("───────────────────────────────────────────────────────────────────────────────"));
        Serial.println();
        return;
    }

    Serial.println(F("OK"));

    Serial.println();
    Serial.println(F("📄 Listing filesystem contents:"));
    Serial.println(F("---------------------------------------------------------------"));

    File root = LittleFS.open("/");
    if (!root || !root.isDirectory())
    {
        Serial.println(F("❌ Failed to open root directory."));
        Serial.println(F("───────────────────────────────────────────────────────────────────────────────"));
        Serial.println();
        return;
    }

    File file = root.openNextFile();
    uint16_t fileCount = 0;
    uint32_t totalSize = 0;

    while (file)
    {
        fileCount++;
        totalSize += file.size();

        if (file.isDirectory())
        {
            Serial.printf("📁  %-24s\n", file.name());
        }
        else
        {
            Serial.printf("📄  %-24s  %8u bytes\n", file.name(), file.size());
        }

        file = root.openNextFile();
    }

    Serial.println(F("---------------------------------------------------------------"));
    Serial.printf("📊 %u entries, %u bytes total\n", fileCount, totalSize);
    Serial.println(F("✅ LittleFS mounted and ready."));
    Serial.println(F("───────────────────────────────────────────────────────────────────────────────"));
    Serial.println();
}

bool waitForTimeVerbose(uint32_t timeoutMs)
{

    configTime(0, 0,
               "pool.ntp.org",
               "time.google.com",
               "time.cloudflare.com");
    setenv("TZ", "CET-1CEST,M3.5.0/2,M10.5.0/3", 1);
    tzset();

    // Zurich, Paris, Berlin, Rome, Madrid
    // setenv("TZ", "CET-1CEST,M3.5.0/2,M10.5.0/3", 1);

    // London
    // setenv("TZ", "GMT0BST,M3.5.0/1,M10.5.0/2", 1);

    // Moscow (no DST)
    // setenv("TZ", "MSK-3", 1);

    // More https://support.cyberdata.net/portal/en/kb/articles/010d63c0cfce3676151e1f2d5442e311?utm_source=chatgpt.com

    time_t now;
    uint32_t start = millis();

    Serial.println(F("───────────────────────────────────────────────────────────────────────────────"));
    Serial.println(F("[TIME] 🕒 SNTP Time Synchronization"));
    Serial.println(F("───────────────────────────────────────────────────────────────────────────────"));

    // Network summary
    Serial.printf("[NET ] 📡 IP   : %s\n", WiFi.localIP().toString().c_str());
    Serial.printf("[NET ] 🌐 DNS  : %s\n", WiFi.dnsIP().toString().c_str());

    // DNS resolution test
    Serial.print(F("[TIME] 🌐 Resolving NTP server... "));
    IPAddress ntpIP;
    if (WiFi.hostByName("pool.ntp.org", ntpIP))
    {
        Serial.print(F("OK → "));
        Serial.println(ntpIP);
    }
    else
    {
        Serial.println(F("❌ FAILED"));
    }

    // SNTP configuration

    Serial.println();
    Serial.println(F("[TIME] ⚙️  SNTP configuration"));
    Serial.println(F("---------------------------------------------------------------"));

    int mode = sntp_getoperatingmode();

    Serial.print("Mode        : ");
    if (mode == SNTP_OPMODE_POLL)
    {
        Serial.println("POLL");
    }
    else if (mode == SNTP_OPMODE_LISTENONLY)
    {
        Serial.println("LISTEN");
    }
    else
    {
        Serial.println("UNKNOWN");
    }
    Serial.printf("Server [0]  : %s\n", sntp_getservername(0) ? sntp_getservername(0) : "(none)");
    Serial.printf("Server [1]  : %s\n", sntp_getservername(1) ? sntp_getservername(1) : "(none)");
    Serial.printf("Server [2]  : %s\n", sntp_getservername(2) ? sntp_getservername(2) : "(none)");

    Serial.println(F("---------------------------------------------------------------"));
    Serial.println();

    // Wait loop
    Serial.print(F("[TIME] ⏳ Waiting for valid epoch"));

    while (millis() - start < timeoutMs)
    {
        time(&now);

        Serial.print(F(" · "));
        Serial.print(now);

        if (now > 1700000000)
        {
            tm t;
            Serial.println();
            Serial.println(F("[TIME] 📅 Current time"));

            gmtime_r(&now, &t);
            Serial.printf("UTC   : %04d-%02d-%02d %02d:%02d:%02d\n",
                          t.tm_year + 1900, t.tm_mon + 1, t.tm_mday,
                          t.tm_hour, t.tm_min, t.tm_sec);

            localtime_r(&now, &t);
            Serial.printf("LOCAL : %04d-%02d-%02d %02d:%02d:%02d\n",
                          t.tm_year + 1900, t.tm_mon + 1, t.tm_mday,
                          t.tm_hour, t.tm_min, t.tm_sec);

            Serial.println();
            Serial.println(F("[TIME] ✅ SNTP synchronization successful"));
            Serial.println(F("───────────────────────────────────────────────────────────────────────────────"));
            Serial.println();
            return true;
        }

        delay(1000);
    }

    Serial.println();
    Serial.println(F("[TIME] ❌ SNTP synchronization TIMEOUT"));
    Serial.println(F("↪ No valid NTP response received."));
    Serial.println(F("───────────────────────────────────────────────────────────────────────────────"));
    Serial.println();

    return false;
}

void printTimes()
{
    time_t now;
    tm t;

    time(&now);

    gmtime_r(&now, &t);
    Serial.printf("UTC   : %04d-%02d-%02d %02d:%02d:%02d\n",
                  t.tm_year + 1900, t.tm_mon + 1, t.tm_mday,
                  t.tm_hour, t.tm_min, t.tm_sec);

    localtime_r(&now, &t);
    Serial.printf("LOCAL : %04d-%02d-%02d %02d:%02d:%02d\n",
                  t.tm_year + 1900, t.tm_mon + 1, t.tm_mday,
                  t.tm_hour, t.tm_min, t.tm_sec);
}

void drawLocalAndUTCTime(int16_t y, int16_t margin)
{
    time_t now;
    tm t;
    time(&now);
    y = y - 20;

    // ── Font setup ─────────────────────────────────────────
    tft.setTextFont(1); // REQUIRED for FreeFonts
    tft.setFreeFont(&RobotoMono_Medium13pt7b);
    tft.setTextColor(TFT_WHITE, TFT_BLACK);

    const int lineSpacing = 28;

    // Useful metrics for clearing
    const int timeY = y + lineSpacing;
    const int timeH = tft.fontHeight() + 4;       // +padding
    const int timeW = tft.textWidth("88:88") + 6; // +padding

    // ── Labels ─────────────────────────────────────────────
    tft.setTextDatum(TL_DATUM);
    tft.drawString("Local", margin, y);

    tft.setTextDatum(TR_DATUM);
    tft.drawString("UTC", tft.width() - margin - 12, y);

    // ── Local time ─────────────────────────────────────────
    localtime_r(&now, &t);
    char buf[6];
    snprintf(buf, sizeof(buf), "%02d:%02d", t.tm_hour, t.tm_min);

    // Clear local time area (Top-Left anchored)
    tft.fillRect(margin - 2, timeY - 2, timeW, timeH - 10, TFT_BLACK);

    tft.setTextDatum(TL_DATUM);
    tft.drawString(buf, margin, timeY);

    // ── UTC time ───────────────────────────────────────────
    gmtime_r(&now, &t);
    snprintf(buf, sizeof(buf), "%02d:%02d", t.tm_hour, t.tm_min);

    int xRight = tft.width() - margin;

    // Clear UTC time area (Top-Right anchored -> rectangle starts at xRight - timeW)
    tft.fillRect(xRight - timeW + 2, timeY - 2, timeW + 4, timeH - 10, TFT_BLACK);

    tft.setTextDatum(TR_DATUM);
    tft.drawString(buf, xRight, timeY);

    // Restore safe defaults
    tft.setTextDatum(TL_DATUM);
}

void updateTimeIfMinuteChanged()
{
    time_t now;
    tm t;

    time(&now);
    localtime_r(&now, &t);

    if (t.tm_min != lastDrawnMinute)
    {
        lastDrawnMinute = t.tm_min;

        drawLocalAndUTCTime(240, 10);
    }
}
void printMQTTConnectionOK()
{
    time_t now;
    tm t;
    time(&now);
    localtime_r(&now, &t);

    char ts[16];
    snprintf(ts, sizeof(ts), "%02d:%02d:%02d",
             t.tm_hour, t.tm_min, t.tm_sec);

    Serial.printf("[MQTT] Connection OK @ %s\n", ts);
}

bool switchAntenna(uint8_t antenna)
{
    Serial.printf("[HW ] switchAntenna(%u)\n", antenna);

    char dtmf = '\0';
    if (antenna >= 1 && antenna <= 9)
        dtmf = char('0' + antenna);
    else if (antenna == 10)
        dtmf = '0';
    else if (antenna == 11)
        dtmf = '*';
    else
    {
        Serial.println("[HW ] Invalid antenna index (must be 1..11)");
        return false;
    }

    Serial.printf("[HW ] DTMF = '%c'\n", dtmf);

    // EXACT same behavior as the working player
    return ht9200PlayOne(dtmf, 60, 1);
}

uint8_t ht9200CodeFromChar(char c)
{
    switch (c)
    {
    case '1':
        return 0x01;
    case '2':
        return 0x02;
    case '3':
        return 0x03;
    case '4':
        return 0x04;
    case '5':
        return 0x05;
    case '6':
        return 0x06;
    case '7':
        return 0x07;
    case '8':
        return 0x08;
    case '9':
        return 0x09;
    case '0':
        return 0x0A;
    case '*':
        return 0x0B;
    case '#':
        return 0x0C;
    case 'A':
    case 'a':
        return 0x0D;
    case 'B':
    case 'b':
        return 0x0E;
    case 'C':
    case 'c':
        return 0x0F;
    case 'D':
    case 'd':
        return 0x00;
    default:
        return 0xFF;
    }
}

bool ht9200PlayOne(char symbol, uint16_t toneMs, uint16_t gapMs)
{
    uint8_t code = ht9200CodeFromChar(symbol);
    if (code == 0xFF)
    {
        Serial.print("Skipping invalid symbol: ");
        Serial.println(symbol);
        return false;
    }

    Serial.print("Tone: ");
    Serial.println(symbol);

    ht9200Send5Bits(code);
    delay(toneMs);
    ht9200Send5Bits(0x1F);
    delay(gapMs);

    return true;
}
void ht9200Send5Bits(uint8_t code5)
{
    for (int i = 0; i < 5; i++)
    {
        digitalWrite(PIN_DIN, (code5 >> i) & 0x01);
        digitalWrite(PIN_CLK, LOW);
        delayMicroseconds(80);
        digitalWrite(PIN_CLK, HIGH);
        delayMicroseconds(80);
    }
}