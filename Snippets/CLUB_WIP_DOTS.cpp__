void drawKeypadNavButton(bool force)
{
    static bool drawn = false;

    // Only show the nav button on MAIN page (DIAL) — nowhere else
    if (gView != VIEW_DIAL)
    {
        drawn = false; // important: allow redraw when we come back to DIAL
        return;
    }

    if (!force && drawn)
        return;

    uint16_t fill = tft.color565(90, 90, 90);
    uint16_t border = TFT_LIGHTGREY;

    tft.fillRoundRect(KEYPAD_NAV_X, KEYPAD_NAV_Y, KEYPAD_NAV_W, KEYPAD_NAV_H, KEYPAD_NAV_R, fill);
    tft.drawRoundRect(KEYPAD_NAV_X, KEYPAD_NAV_Y, KEYPAD_NAV_W, KEYPAD_NAV_H, KEYPAD_NAV_R, border);

    tft.setTextDatum(MC_DATUM);
    tft.setTextFont(2);
    // tft.setFreeFont(&JetBrainsMono_Bold8pt7b);
    tft.setTextSize(1);
    tft.setTextColor(TFT_WHITE, fill);
    tft.drawString("RELAYS", KEYPAD_NAV_X + KEYPAD_NAV_W / 2, KEYPAD_NAV_Y + KEYPAD_NAV_H / 2);

    drawn = true;
}
