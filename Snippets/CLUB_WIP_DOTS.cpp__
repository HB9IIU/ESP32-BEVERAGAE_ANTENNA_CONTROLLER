    }

    delay(50);
}

void encodertestTFT()
{
    digitalWrite(TFT_BLP, HIGH);
    // encoder test with TFT animation (improved visibility)
    Serial.println("=== Encoder test mode (TFT ring animation) ===");

    // better color contrast
    uint16_t ledOff = tft.color565(70, 70, 70); // dim gray (more visible)
    uint16_t ledOn = TFT_GREEN;                 // bright green
    uint16_t ledCenter = TFT_YELLOW;            // center flash color

    // clear screen
    tft.fillScreen(TFT_BLACK);
    tft.setTextColor(TFT_WHITE, TFT_BLACK);
    tft.setTextFont(2);
    tft.drawCentreString("Encoder Test Mode", tft.width() / 2, 10, 4);

    // ring geometry
    const uint8_t NUM_LEDS = 16;
    const int16_t cx = tft.width() / 2;
    const int16_t cy = tft.height() / 2 + 10;
    const int16_t RADIUS = 90;
    const uint8_t LED_R = 9;

    // precompute LED positions
    int16_t ledX[NUM_LEDS], ledY[NUM_LEDS];
    for (uint8_t i = 0; i < NUM_LEDS; i++)
    {
        float a = (360.0f / NUM_LEDS) * i * PI / 180.0f;
        ledX[i] = cx + RADIUS * sin(a);
        ledY[i] = cy - RADIUS * cos(a);
    }

    // draw ring LEDs off
    for (uint8_t i = 0; i < NUM_LEDS; i++)
        tft.fillCircle(ledX[i], ledY[i], LED_R, ledOff);

    // encoder tracking
    int dt = digitalRead(PIN_ENC_DT);
    int clk = digitalRead(PIN_ENC_CLK);
    uint8_t lastState = (dt << 1) | clk;
    int8_t encoderAccum = 0;
    int8_t ledIndex = 0;
    unsigned long counter = 0;

    // initial active LED
    tft.fillCircle(ledX[ledIndex], ledY[ledIndex], LED_R, ledOn);

    while (1)
    {
        dt = digitalRead(PIN_ENC_DT);
        clk = digitalRead(PIN_ENC_CLK);
        uint8_t currentState = (dt << 1) | clk;
        uint8_t index = (lastState << 2) | currentState;
        int8_t movement = encTable[index];

        if (movement != 0)
        {
            encoderAccum += movement;
            lastState = currentState;

            if (encoderAccum >= STEPS_PER_NOTCH)
            {
                encoderAccum = 0;
                counter++;
                tft.fillCircle(ledX[ledIndex], ledY[ledIndex], LED_R, ledOff);
                ledIndex = (ledIndex + 1) % NUM_LEDS;
                tft.fillCircle(ledX[ledIndex], ledY[ledIndex], LED_R, ledOn);
                Serial.printf("%lu CW\n", counter);
            }
            else if (encoderAccum <= -STEPS_PER_NOTCH)
            {
                encoderAccum = 0;
                counter++;
                tft.fillCircle(ledX[ledIndex], ledY[ledIndex], LED_R, ledOff);
                ledIndex = (ledIndex - 1 + NUM_LEDS) % NUM_LEDS;
                tft.fillCircle(ledX[ledIndex], ledY[ledIndex], LED_R, ledOn);
                Serial.printf("%lu CCW\n", counter);
            }
        }
        else
        {
            lastState = currentState;
        }

        // button animation
        if (digitalRead(PIN_ENC_SW) == LOW)
        {
            Serial.printf("[%lu] Button pressed\n", counter);

            // flash center with a "pulse" animation
            for (int r = 5; r <= 20; r += 3)
            {
                tft.fillCircle(cx, cy, r, ledCenter);
                delay(20);
            }
            delay(80);
            for (int r = 20; r >= 5; r -= 3)
            {
                tft.fillCircle(cx, cy, r, TFT_BLACK);
                delay(20);
            }

            // restore LED ring state
            for (uint8_t i = 0; i < NUM_LEDS; i++)
                tft.fillCircle(ledX[i], ledY[i], LED_R, ledOff);
            tft.fillCircle(ledX[ledIndex], ledY[ledIndex], LED_R, ledOn);

            delay(200);
        }

        delay(2);
    }
}

void drawWiFiIndicator()
{
    int16_t x = 20;
    int16_t y = 310;
    int barWidth = 5;
    int barHeight = 5;
    int barGap = 3;

    // clear background area for widget + text
    tft.fillRect(x - 3, y - 20, 60, 28, TFT_BLACK);

    if (WiFi.status() != WL_CONNECTED)
    {
        tft.setTextColor(TFT_RED, TFT_BLACK);
        tft.setTextFont(2);
        tft.drawString("x", x + 10, y - 8);
        tft.setTextFont(1);
        tft.drawString("No WiFi", x, y);
        return;
    }

    long rssi = WiFi.RSSI();          // dBm
    rssi = constrain(rssi, -90, -40); // safety limits

    // map RSSI -> 0..1 smooth factor
    float t = (float)(rssi + 90) / 50.0f;

    // smooth RGB gradient: red → yellow → green
    uint8_t r, g, b;
    if (t < 0.5f)
    {
        t *= 2.0f; // 0–1
        r = 255;
        g = (uint8_t)(t * 255);
        b = 0;
    }
    else
    {
        t = (t - 0.5f) * 2.0f; // 0–1
        r = (uint8_t)(255 * (1.0f - t));
        g = 255;
        b = 0;
    }
    uint16_t color = tft.color565(r, g, b);

    // discrete level for bar count
    uint8_t level = 0;
    if (rssi > -55)
        level = 4;
    else if (rssi > -65)
        level = 3;
    else if (rssi > -75)
        level = 2;
    else if (rssi > -85)
        level = 1;
    else
        level = 0;

    // draw all 4 bars freshly each time (prevents old color residue)
    for (uint8_t i = 0; i < 4; i++)
    {
        int barH = (i + 1) * barHeight;
        int bx = x + i * (barWidth + barGap);
        int by = y - barH - 5;

        if (i < level)
            tft.fillRect(bx, by, barWidth, barH, color);
        else
        {
            // clear bar area first to remove previous fill
            tft.fillRect(bx, by, barWidth, barH, TFT_BLACK);
            tft.drawRect(bx, by, barWidth, barH, TFT_DARKGREY);
        }
    }

    // --- Draw RSSI text below ---
    char buf[12];
    snprintf(buf, sizeof(buf), "%ld dB", rssi);
    tft.setTextFont(1);
    tft.setTextColor(TFT_LIGHTGREY, TFT_BLACK);
    tft.drawCentreString(buf, x + 20, y + 3, 1);
}
void drawMQTTIndicator()
{
    int16_t w = tft.width();
    int16_t h = tft.height();

    int16_t cx = w - 20; // bottom-right corner
    int16_t cy = h - 10;
    uint8_t r = 6;

    // -------------------------------------------------
    // Always draw WHITE outer ring (firmware alive)
    // -------------------------------------------------
    tft.drawCircle(cx, cy, r + 2, TFT_WHITE);

    // -------------------------------------------------
    // Determine states
    // -------------------------------------------------
    bool mqttOk = mqttClient.connected();

    bool remoteRecentlyActive =
        (lastRemoteInteractionMs != 0) &&
        ((millis() - lastRemoteInteractionMs) < REMOTE_ACTIVE_MS);

    static unsigned long lastBlink = 0;
    static bool blinkState = false;
    unsigned long now = millis();

    uint16_t fillColor = TFT_BLACK; // default: empty

    // -------------------------------------------------
    // RED: MQTT down
    // -------------------------------------------------
    if (!mqttOk)
    {
        fillColor = TFT_RED;
        blinkState = true; // solid red
    }
    // -------------------------------------------------
    // GREEN blinking: REMOTE activity
    // -------------------------------------------------
    else if (remoteRecentlyActive)
    {
        fillColor = TFT_GREEN;

        if (now - lastBlink >= 400)
        {
            blinkState = !blinkState;
            lastBlink = now;
        }
    }
    // -------------------------------------------------
    // GREEN solid: MQTT OK, no REMOTE activity
    // -------------------------------------------------
    else
    {
        fillColor = TFT_GREEN;
        blinkState = true; // solid
    }

    // -------------------------------------------------
    // Draw filled indicator
    // -------------------------------------------------
    if (blinkState)
    {
        tft.fillCircle(cx, cy, r, fillColor);
    }
    else
    {
        // blinking OFF phase → clear inner only
        tft.fillCircle(cx, cy, r, TFT_BLACK);
    }
}

