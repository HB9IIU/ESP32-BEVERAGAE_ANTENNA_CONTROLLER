// ============================================================================
//                                    SETUP
// ============================================================================
void setup()
{
    // ──────────────────────────────────────────────
    // 1️⃣ SERIAL + INTRO
    // ──────────────────────────────────────────────
    Serial.begin(115200);
    displayIntroBanner();
    printSystemInfo();

    // ──────────────────────────────────────────────
    // 2️⃣ BASIC HARDWARE INIT
    // ──────────────────────────────────────────────
    pinMode(TFT_BLP, OUTPUT);
    initEncoderPins();


    tft.init();
    tft.setRotation(1);
    tft.fillScreen(TFT_BLACK);

    checkAndApplyTFTCalibrationData(false);

    // uncomment below to test encoder separately
    // encodertestTFT();
    digitalWrite(TFT_BLP, LOW);
    displayPicture("logo", 1500);

    // ──────────────────────────────────────────────
    // 3️⃣ DEFINE TFT COLOR PALETTE
    // ──────────────────────────────────────────────
    TftGrey = tft.color565(100, 100, 100);
    TftRed = tft.color565(255, 0, 0);
    TftYellow = tft.color565(255, 255, 0);
    TftGreen = tft.color565(0, 255, 0);

    // ──────────────────────────────────────────────
    // 4️⃣ FACTORY RESET (if button held)
    // ──────────────────────────────────────────────
    if (!digitalRead(PIN_ENC_SW))
    {
        performFactoryResetAll();
    }

    // ──────────────────────────────────────────────
    // 5️⃣ START CONFIGURATION PORTAL
    // ──────────────────────────────────────────────
    HB9IIUPortal::begin("beverage");

    // ──────────────────────────────────────────────
    // 6️⃣ CONNECTED → NORMAL MODE
    // ──────────────────────────────────────────────
    if (HB9IIUPortal::isConnected())
    {
        gPanelIdStr = getStoredCallsign();
        PANEL_ID = gPanelIdStr.c_str();

        Serial.println(F("──────────────────────────────────────────────"));
        Serial.printf("[APP] 📡 WiFi connected successfully.\n");
        Serial.printf("   ↳ Remote Panel ID  : %s\n", PANEL_ID);
        Serial.printf("   ↳ Local IP Address : %s\n", WiFi.localIP().toString().c_str());
        Serial.println(F("──────────────────────────────────────────────\n"));

        displayPicture("remote", 0);
        drawRemoteStationLabel();

        mqttSetup();
        setupElegantOTA();

        delay(1000);
        displayPicture("azimuthalMap", 0);
        initAntennaDial();
 
        Serial.println(F("✅ Setup complete.\n"));
    }

    // ──────────────────────────────────────────────
    // 7️⃣ NOT CONNECTED → AP or CONNECTING
    // ──────────────────────────────────────────────
    else
    {
        wifi_mode_t mode = WiFi.getMode();
        wl_status_t status = WiFi.status();

        Serial.println(F("──────────────────────────────────────────────"));
        Serial.println(F("[APP] ⚠️  WiFi not connected at setup stage."));
        Serial.printf("   ↳ Current WiFi mode : %s\n",
                      (mode == WIFI_AP)       ? "Access Point (AP)"
                      : (mode == WIFI_STA)    ? "Station (Client)"
                      : (mode == WIFI_AP_STA) ? "AP + STA (mixed)"
                                              : "WiFi OFF");

        Serial.printf("   ↳ WiFi status       : %s\n",
                      (status == WL_NO_SSID_AVAIL)    ? "No SSID available"
                      : (status == WL_CONNECT_FAILED) ? "Connection failed"
                      : (status == WL_DISCONNECTED)   ? "Disconnected"
                      : (status == WL_IDLE_STATUS)    ? "Idle (trying...)"
                      : (status == WL_CONNECTED)      ? "Connected (shouldn't be here)"
                                                      : "Unknown");
        Serial.println();

        Serial.println(F("   ↳ Detected AP mode → portal will draw its own QR code and setup UI."));
        Serial.println(F("──────────────────────────────────────────────\n"));

        // ✅ Nothing else here: HB9IIUPortal handles TFT display.
        // Just return — portal stays active, QR code stays visible.
    }
}

// ============================================================================
//                                    LOOP
// ============================================================================
void loop()
{
    // ──────────────────────────────────────────────
    // 1️⃣ Keep portal alive at all times (QR / Web UI)
    // ──────────────────────────────────────────────
    HB9IIUPortal::loop();

    // ──────────────────────────────────────────────
    // 2️⃣ Run normal logic only when connected
    // ──────────────────────────────────────────────
    if (HB9IIUPortal::isConnected())
    {
       
        otaServer.handleClient();
  ElegantOTA.loop();
       
       
        updateEncoder();
        mqttClient.loop();

        // --- Animate antenna pulse ---
        if (!awaitingClubConfirm &&
            !equirectangularMapIsDisplayed &&
            selectedAntenna >= ANTENNA_MIN &&
            selectedAntenna <= ANTENNA_MAX)
        {
            unsigned long now = millis();

            if (now - lastPulseUpdate >= PULSE_INTERVAL_MS)
            {
                lastPulseUpdate = now;
                pulseBrightness += pulseDirection;

                if (pulseBrightness <= 100 || pulseBrightness >= 255)
                {
                    pulseDirection = -pulseDirection;
                    pulseBrightness = constrain(pulseBrightness, 100, 255);
                }

                uint16_t color = tft.color565(0, pulseBrightness, 0);
                tft.drawCircle(dotX[selectedAntenna], dotY[selectedAntenna],
                               DIAL_DOT_RADIUS + 1, TFT_WHITE);
                drawAntennaDot(selectedAntenna, color);
            }
        }

        // --- WiFi signal indicator update ---
        static long lastRssi = 0;
        long rssi = WiFi.RSSI();
        if (abs(rssi - lastRssi) > 2)
        {
            drawWiFiIndicator();
            lastRssi = rssi;
        }

        // --- MQTT indicator ---
        static unsigned long lastMQTTDraw = 0;
        if (millis() - lastMQTTDraw > 100)
        {
            lastMQTTDraw = millis();
            drawMQTTIndicator();
        }

        // --- MQTT auto-reconnect watchdog ---
        static unsigned long lastMQTTCheck = 0;
        const unsigned long MQTT_RECHECK_MS = 10000; // every 10s
        if (millis() - lastMQTTCheck >= MQTT_RECHECK_MS)
        {
            lastMQTTCheck = millis();
            if (!mqttEnsureConnected())
                Serial.println(F("[MQTT] Reconnect attempt failed"));
            else
                Serial.println(F("[MQTT] Connection OK"));
        }

        // --- Touchscreen toggle (map <-> world view) ---
        static unsigned long lastTouchCheck = 0;
        if (millis() - lastTouchCheck > 100)
        {
            lastTouchCheck = millis();

            uint16_t x, y;
            if (tft.getTouch(&x, &y))
            {
                equirectangularMapIsDisplayed = !equirectangularMapIsDisplayed;

                if (!equirectangularMapIsDisplayed)
                {
                    displayPicture("azimuthalMap", 0);
                    initAntennaDial();
                }
                else
                {
                    Serial.printf("[INFO] selected antenna=%d\n", selectedAntenna);
                    tft.fillScreen(TFT_BLACK);
                    displayPicture("equirectangularMap", 0);
                    float az = dotAzimuthDeg[preSelectedAntenna];
                    plotGreatCircle(HOME_LAT_DEG, HOME_LON_DEG, az, TFT_GOLD, 2);
                    updateMapBottomLabel();
                    drawWiFiIndicator();
                }
            }
        }
    }

    // ──────────────────────────────────────────────
    // 3️⃣ When NOT connected (portal active)
    // ──────────────────────────────────────────────
    else
    {
        static unsigned long lastPortalMsg = 0;
        if (millis() - lastPortalMsg > 5000)
        {
            lastPortalMsg = millis();
            Serial.println(F("[PORTAL] Waiting for WiFi configuration..."));
        }
    }

    delay(5); // gentle yield
}

// ============================================================================
//                            WIFI / MQTT HELPERS
// ============================================================================

void mqttSetup()
{
    Serial.println(F("[MQTT] Setting up secure client ..."));

    mqttSecureClient.setInsecure();
    mqttSecureClient.setTimeout(15000);

    mqttClient.setServer(MQTT_HOST, MQTT_PORT);
    mqttClient.setCallback(mqttCallback);

    mqttEnsureConnected();
}

bool mqttEnsureConnected()
{
    if (WiFi.status() != WL_CONNECTED)
        return false;

    if (mqttClient.connected())
        return true;

    Serial.println(F("[MQTT] (Re)connecting to broker..."));

    String clientId = String("cyd-remote-") + String((uint32_t)ESP.getEfuseMac(), HEX);

    if (mqttClient.connect(clientId.c_str(), MQTT_USER, MQTT_PASSWD))
    {
        Serial.println(F("[MQTT] Connected to HiveMQ Cloud"));

        // Subscribe to antenna state from club
        if (mqttClient.subscribe(MQTT_TOPIC_STATE))
        {
            Serial.print(F("[MQTT] Subscribed to "));
            Serial.println(MQTT_TOPIC_STATE);
        }
        else
        {
            Serial.println(F("[MQTT] Failed to subscribe to antenna/state"));
        }

        // Subscribe to heartbeat from club
        if (mqttClient.subscribe(MQTT_TOPIC_HEARTBEAT))
        {
            Serial.print(F("[MQTT] Subscribed to "));
            Serial.println(MQTT_TOPIC_HEARTBEAT);
        }
        else
        {
            Serial.println(F("[MQTT] Failed to subscribe to antenna/heartbeat"));
        }

        return true;
    }
    else
    {
        Serial.print(F("[MQTT] Connection FAILED, rc="));
        Serial.println(mqttClient.state());
        return false;
    }
}

// Incoming MQTT messages (state + heartbeat from club)
void mqttCallback(char *topic, byte *payload, unsigned int length)
{
    if (strcmp(topic, MQTT_TOPIC_STATE) == 0)
    {
        char buf[200];
        if (length >= sizeof(buf))
            length = sizeof(buf) - 1;
        memcpy(buf, payload, length);
        buf[length] = '\0';

        int sel = 0, pre = 0;
        if (sscanf(buf, "{\"selected\":%d,\"pre\":%d", &sel, &pre) == 2)
        {
            selectedAntenna = sel;
            preSelectedAntenna = pre;
            awaitingClubConfirm = false;

            Serial.printf("[STATE] CLUB confirmed antenna %u\n", selectedAntenna);

            updateDialColors();
            updateDynamicCornerLabels();
        }
    }

    if (strcmp(topic, MQTT_TOPIC_HEARTBEAT) == 0)
    {
        lastClubStateMs = millis();
    }
}

// Publish a SELECT command to the club
// Called on every encoder detent (immediate selection)
void publishSelectCommand()
{
    Serial.println(F("[REMOTE] publishSelectCommand() called"));

    if (!mqttEnsureConnected())
    {
        Serial.println(F("[REMOTE] mqttEnsureConnected() FAILED, not publishing."));
        return;
    }

    char payload[80];
    snprintf(payload, sizeof(payload),
             "{\"select\":%u,\"source\":\"%s\"}",
             selectedAntenna, PANEL_ID);

    Serial.print(F("[REMOTE] SELECT -> "));
    Serial.print(MQTT_TOPIC_CMD);
    Serial.print(F(" : "));
    Serial.println(payload);

    bool ok = mqttClient.publish(MQTT_TOPIC_CMD, payload);
    Serial.print(F("[REMOTE] mqttClient.publish(SELECT) returned: "));
    Serial.println(ok ? F("true") : F("false"));
}

// ============================================================================
//                            SYSTEM INIT HELPERS
// ============================================================================

void initAntennaDial()
{
    Serial.println(F("[INIT] Antenna dial"));

    loadDotConfig();
    ANTENNA_MAX = numDots;

    updateAllDotPositions();
    drawDialBase();

    // IMPORTANT: do NOT reset selectedAntenna / preSelectedAntenna here.
    // We want to keep whatever state we currently have from CLUB/REMOTE.
    updateDialColors();

    updateDynamicCornerLabels();
}

void initEncoderPins()
{
    Serial.println();
    Serial.println(F("───────────────────────────────────────────────────────────────────────────────"));

    // ✅ Correct pin configuration
    pinMode(PIN_ENC_DT, INPUT);        // Encoder A
    pinMode(PIN_ENC_CLK, INPUT);       // Encoder B
    pinMode(PIN_ENC_SW, INPUT_PULLUP); // Encoder button

    // --- Capture initial electrical state ---
    int dt = digitalRead(PIN_ENC_DT);
    int clk = digitalRead(PIN_ENC_CLK);
    int sw  = digitalRead(PIN_ENC_SW);
    lastState = (dt << 1) | clk;

    // --- Explain each line clearly ---
    Serial.println(F("GPIO configuration and idle signal state:"));
    Serial.printf("   ↳ DT  pin : %-2d   (INPUT)  level=%d  → signal A, %s\n",
                  PIN_ENC_DT, dt, dt ? "idle HIGH (open contact)" : "active LOW (closed to GND)");
    Serial.printf("   ↳ CLK pin : %-2d   (INPUT)  level=%d  → signal B, %s\n",
                  PIN_ENC_CLK, clk, clk ? "idle HIGH (open contact)" : "active LOW (closed to GND)");
    Serial.printf("   ↳ SW  pin : %-2d   (INPUT_PULLUP) level=%d  → push-button, %s\n",
                  PIN_ENC_SW, sw, sw ? "released (HIGH)" : "pressed (LOW)");

    Serial.println();
    Serial.printf("   ↳ Initial encoder state: 0b%02d (DT=%d, CLK=%d)\n", lastState, dt, clk);
    Serial.println();
    Serial.println(F("   ✅ Encoder GPIOs all configured as inputs."));
    Serial.println(F("   Encoder lines read HIGH → mechanical contacts are open (idle state)."));
    Serial.println(F("───────────────────────────────────────────────────────────────────────────────"));
    Serial.println();
}


// ============================================================================
//                             ANTENNA DIAL HELPERS
// ============================================================================

void loadDotConfig()
{
    numDots = 11;

    dotAzimuthDeg[1] = 0.0f;
    dotAzimuthDeg[2] = 20.0f;
    dotAzimuthDeg[3] = 45.0f;
    dotAzimuthDeg[4] = 60.0f;
    dotAzimuthDeg[5] = 90.0f;
    dotAzimuthDeg[6] = 135.0f;
    dotAzimuthDeg[7] = 180.0f;
    dotAzimuthDeg[8] = 225.0f;
    dotAzimuthDeg[9] = 275.0f;
    dotAzimuthDeg[10] = 310.0f;
    dotAzimuthDeg[11] = 330.0f;
}

void updateAllDotPositions()
{
    int16_t cx = tft.width() / 2;
    int16_t cy = tft.height() / 2;

    for (uint8_t i = 1; i <= numDots; i++)
    {
        float rad = dotAzimuthDeg[i] * PI / 180.0f;
        dotX[i] = cx + (int16_t)round(DIAL_RING_RADIUS * sin(rad));
        dotY[i] = cy - (int16_t)round(DIAL_RING_RADIUS * cos(rad));
    }
}

void setDotAzimuth(uint8_t index, float azimuthDeg)
{
    if (index < 1 || index > numDots)
        return;

    dotAzimuthDeg[index] = azimuthDeg;

    int16_t cx = tft.width() / 2;
    int16_t cy = tft.height() / 2;
    float rad = azimuthDeg * PI / 180.0f;

    dotX[index] = cx + (int16_t)round(DIAL_RING_RADIUS * sin(rad));
    dotY[index] = cy - (int16_t)round(DIAL_RING_RADIUS * cos(rad));
}

void drawAntennaDot(uint8_t index, uint16_t color)
{
    if (index < 1 || index > numDots)
        return;

    tft.fillCircle(dotX[index], dotY[index], DIAL_DOT_RADIUS, color);
    tft.drawCircle(dotX[index], dotY[index], DIAL_DOT_RADIUS + 1, TFT_WHITE);
}

void drawDialBase()
{
    for (uint8_t i = 1; i <= numDots; i++)
        drawAntennaDot(i, TftGrey);
}

void updateDialColors()
{
    for (uint8_t i = 1; i <= numDots; i++)
    {
        uint16_t color = TftGrey;

        if (i == selectedAntenna)
            color = TftGreen;

        if ((i == preSelectedAntenna) && (preSelectedAntenna != selectedAntenna))
            color = TftRed;

        drawAntennaDot(i, color);
    }
}

// ============================================================================
//                           ENCODER + BUTTON LOGIC
// ============================================================================
//
// On REMOTE, every detent normally:
//   - changes selectedAntenna
//   - sends a SELECT command to the CLUB
//
// BUT: if the great-circle map is currently displayed, the FIRST detent
//      is used only to EXIT the map and return to the main dial,
//      WITHOUT changing antenna and WITHOUT sending MQTT.
// ============================================================================
void updateEncoder()
{
    int dt = digitalRead(PIN_ENC_DT);
    int clk = digitalRead(PIN_ENC_CLK);
    uint8_t currentState = (dt << 1) | clk;

    uint8_t index = (lastState << 2) | currentState;
    int8_t movement = encTable[index];

    static uint8_t trailIndices[TRAIL_LENGTH] = {0};
    static uint8_t trailPos = 0;

    if (movement != 0)
    {
        encoderAccum += movement;
        lastState = currentState;

        if (encoderAccum >= STEPS_PER_NOTCH)
        {
            encoderAccum = 0;

            if (equirectangularMapIsDisplayed)
            {
                equirectangularMapIsDisplayed = false;
                displayPicture("azimuthalMap", 0);
                initAntennaDial();
                return;
            }

            // --- Determine next antenna (CW) ---
            uint8_t next = (pendingAntenna >= ANTENNA_MAX)
                               ? ANTENNA_MIN
                               : (pendingAntenna + 1);

            pendingAntenna = next;
            pendingSelection = true;
            lastEncoderMoveMs = millis();

            // --- Pac-Man Trail update ---
            trailIndices[trailPos] = pendingAntenna;
            trailPos = (trailPos + 1) % TRAIL_LENGTH;

            // --- Clear all non-trail dots ---
            for (uint8_t i = 1; i <= numDots; i++)
            {
                bool inTrail = false;
                for (uint8_t j = 0; j < TRAIL_LENGTH; j++)
                {
                    if (trailIndices[j] == i)
                    {
                        inTrail = true;
                        break;
                    }
                }

                if (!inTrail)
                {
                    uint16_t baseColor = (i == selectedAntenna) ? TFT_GREEN : TftGrey;
                    drawAntennaDot(i, baseColor);
                }
            }

            // --- Draw current yellow dot + halo ---
            tft.drawCircle(dotX[pendingAntenna], dotY[pendingAntenna],
                           DIAL_DOT_RADIUS + 1, TFT_WHITE); // halo
            drawAntennaDot(pendingAntenna, TFT_YELLOW);     // center

            Serial.printf("[REMOTE] ROTATE CW -> hover antenna %u\n", pendingAntenna);
        }

        else if (encoderAccum <= -STEPS_PER_NOTCH)
        {
            encoderAccum = 0;

            if (equirectangularMapIsDisplayed)
            {
                equirectangularMapIsDisplayed = false;
                displayPicture("azimuthalMap", 0);
                initAntennaDial();
                return;
            }

            // --- Determine next antenna (CCW) ---
            uint8_t next = (pendingAntenna <= ANTENNA_MIN)
                               ? ANTENNA_MAX
                               : (pendingAntenna - 1);

            pendingAntenna = next;
            pendingSelection = true;
            lastEncoderMoveMs = millis();

            // --- Pac-Man Trail update ---
            trailIndices[trailPos] = pendingAntenna;
            trailPos = (trailPos + 1) % TRAIL_LENGTH;

            // --- Clear all non-trail dots ---
            for (uint8_t i = 1; i <= numDots; i++)
            {
                bool inTrail = false;
                for (uint8_t j = 0; j < TRAIL_LENGTH; j++)
                {
                    if (trailIndices[j] == i)
                    {
                        inTrail = true;
                        break;
                    }
                }

                if (!inTrail)
                {
                    uint16_t baseColor = (i == selectedAntenna) ? TFT_GREEN : TftGrey;
                    drawAntennaDot(i, baseColor);
                }
            }

            // --- Draw current yellow dot + halo (same color for both directions) ---
            tft.drawCircle(dotX[pendingAntenna], dotY[pendingAntenna],
                           DIAL_DOT_RADIUS + 1, TFT_WHITE); // halo
            drawAntennaDot(pendingAntenna, TFT_YELLOW);     // center

            Serial.printf("[REMOTE] ROTATE CCW -> hover antenna %u\n", pendingAntenna);
        }
    }
    else
    {
        lastState = currentState;
    }

    // --- User stopped rotating: send request after delay ---
    if (pendingSelection && (millis() - lastEncoderMoveMs > SELECTION_DELAY_MS))
    {
        pendingSelection = false;

        if (pendingAntenna != selectedAntenna)
        {
            Serial.printf("[REMOTE] Settled -> request SELECT %u\n", pendingAntenna);
            selectedAntenna = pendingAntenna;

            // --- Clear trail, draw final pending one ---
            for (uint8_t i = 1; i <= numDots; i++)
            {
                if (i == selectedAntenna)
                {
                    tft.drawCircle(dotX[i], dotY[i], DIAL_DOT_RADIUS + 1, TFT_WHITE);
                    drawAntennaDot(i, TFT_YELLOW);
                }
                else
                {
                    drawAntennaDot(i, TftGrey);
                }
            }

            publishSelectCommand();
            awaitingClubConfirm = true;
        }
    }
}

// Button is currently optional; if you want the button
// to also send a SELECT with the current selectedAntenna,
// just keep this function and call updateButton() from loop().
void updateButton()
{
    static int lastButtonSample = HIGH;
    static int stableState = HIGH;

    int reading = digitalRead(PIN_ENC_SW); // HIGH = released, LOW = pressed

    if (reading != lastButtonSample)
    {
        lastDebounceTime = millis();
        lastButtonSample = reading;
    }

    if ((millis() - lastDebounceTime) > debounceDelayMs)
    {
        if (reading != stableState)
        {
            stableState = reading;

            if (stableState == LOW)
            {
                Serial.print(F("[REMOTE] BUTTON: request select "));
                Serial.println(selectedAntenna);

                // Already selected locally; just confirm to CLUB if desired
                publishSelectCommand();
            }
        }
    }
}

// ============================================================================
//                               SPIFFS UTILITIES
// ============================================================================

void mountAndListSPIFFS(uint8_t levels, bool listContent)
{
    Serial.println();

    if (!SPIFFS.begin(true))
    {
        Serial.println(F("❌ Failed to mount SPIFFS."));
        return;
    }
    Serial.println(F("✅ SPIFFS mounted successfully!"));

    if (!listContent)
        return;

    Serial.println(F("📂 Listing SPIFFS content:"));
    fs::File root = SPIFFS.open("/");
    if (!root || !root.isDirectory())
    {
        Serial.println(F("❌ Failed to open root directory or not a directory."));
        return;
    }

    fs::File file = root.openNextFile();
    while (file)
    {
        if (file.isDirectory())
        {
            Serial.print(F("  📁 DIR : "));
            Serial.println(file.name());
            if (levels)
                mountAndListSPIFFS(levels - 1, true);
        }
        else
        {
            Serial.print(F("  📄 FILE: "));
            Serial.print(file.name());
            Serial.print(F("\tSIZE: "));
            Serial.println(file.size());
        }
        file = root.openNextFile();
    }

    size_t total = SPIFFS.totalBytes();
    size_t used = SPIFFS.usedBytes();
    size_t free = total - used;
    float pctFree = (total > 0) ? ((float)free / total) * 100.0f : 0.0f;

    Serial.println();
    Serial.println(F("📊 SPIFFS Usage Info:"));
    Serial.printf("   📦 Total: %u bytes\n", (unsigned)total);
    Serial.printf("   📂 Used : %u bytes\n", (unsigned)used);
    Serial.printf("   📭 Free : %u bytes (%.2f%%)\n", (unsigned)free, pctFree);
    Serial.println();
}

// ============================================================================
//                            PNGdec CALLBACKS + DRAW
// ============================================================================

void *fileOpen(const char *filename, int32_t *size)
{
    String fullPath = "/" + String(filename);
    pngFile = SPIFFS.open(fullPath, "r");
    if (!pngFile)
        return nullptr;

    *size = pngFile.size();
    return (void *)&pngFile;
}

void fileClose(void *handle)
{
    ((fs::File *)handle)->close();
}

int32_t fileRead(PNGFILE *handle, uint8_t *buffer, int32_t length)
{
    return ((fs::File *)handle->fHandle)->read(buffer, length);
}

int32_t fileSeek(PNGFILE *handle, int32_t position)
{
    return ((fs::File *)handle->fHandle)->seek(position);
}

void pngDrawCallback(PNGDRAW *pDraw)
{
    static uint16_t lineBuffer[480];
    png.getLineAsRGB565(pDraw, lineBuffer, PNG_RGB565_BIG_ENDIAN, 0xFFFFFFFF);
    tft.pushImage(0, pDraw->y, pDraw->iWidth, 1, lineBuffer);
}

void displayPNGfromSPIFFS(const char *filename, int duration_ms)
{
    if (!SPIFFS.begin(true))
    {
        Serial.println(F("Failed to mount SPIFFS in displayPNGfromSPIFFS!"));
        return;
    }

    int16_t rc = png.open(filename, fileOpen, fileClose,
                          fileRead, fileSeek, pngDrawCallback);

    if (rc == PNG_SUCCESS)
    {
        Serial.printf("Displaying PNG: %s\n", filename);
        tft.startWrite();
        png.decode(nullptr, 0);
        tft.endWrite();
    }
    else
    {
        Serial.println(F("PNG decode failed."));
    }

    if (duration_ms > 0)
        delay(duration_ms);
}

// ============================================================================
//                           CORNER TEXT / OVERLAY
// ============================================================================
void updateDynamicCornerLabels()
{
    static uint8_t lastAntenna = 255;
    static int lastAzimuth = -999;

    int16_t w = tft.width();

    // --- Retrieve current values ---
    uint8_t ant = preSelectedAntenna;
    int az = round(dotAzimuthDeg[ant]);

    // --- Label font ---
    tft.setTextFont(2);
    tft.setTextSize(1);
    tft.setTextColor(TFT_WHITE, TFT_BLACK);

    // --- Left side (Antenna) ---
    tft.setTextDatum(TL_DATUM);
    tft.drawString("Antenna", 6, 2);

    // --- Right side (Azimuth) ---
    tft.setTextDatum(TR_DATUM);
    tft.drawString("Azimuth", w - 6, 2);

    // --- Value font ---
    tft.setTextFont(4);
    tft.setTextSize(1);

    // --- Antenna value (left) ---
    char bufAnt[8];
    snprintf(bufAnt, sizeof(bufAnt), "%u", ant);

    if (ant != lastAntenna)
    {
        // erase previous value (print old one in black)
        char bufOld[8];
        snprintf(bufOld, sizeof(bufOld), "%u", lastAntenna);
        tft.setTextColor(TFT_BLACK, TFT_BLACK);
        tft.setTextDatum(TR_DATUM);
        tft.drawString(bufOld, 40, 18);

        // draw new one
        tft.setTextColor(TFT_WHITE, TFT_BLACK);
        tft.setTextDatum(TR_DATUM);
        tft.drawString(bufAnt, 40, 18);

        lastAntenna = ant;
    }

    // --- Azimuth value (right) ---
    char bufAz[16];
    snprintf(bufAz, sizeof(bufAz), "%d°", az);

    if (az != lastAzimuth)
    {
        char bufOld[16];
        snprintf(bufOld, sizeof(bufOld), "%d°", lastAzimuth);
        tft.setTextColor(TFT_BLACK, TFT_BLACK);
        tft.setTextDatum(TR_DATUM);
        tft.drawString(bufOld, w, 18);

        tft.setTextColor(TFT_WHITE, TFT_BLACK);
        tft.setTextDatum(TR_DATUM);
        tft.drawString(bufAz, w, 18);

        lastAzimuth = az;
    }
}

String getStoredCallsign()
{
    String cs;

    if (preferences.begin("config", true)) // read-only
    {
        cs = preferences.getString("callsign", "");
        preferences.end();
    }

    return cs;
}

// -----------------------------------------------------------------------------
//                         GREAT-CIRCLE / MAP HELPERS
// -----------------------------------------------------------------------------

// Convert latitude/longitude (deg) to TFT pixel coordinates (x,y)
void latLonToXY(float lat_deg, float lon_deg, int16_t &x, int16_t &y)
{
    // Clamp latitude just in case
    if (lat_deg > 90.0f)
        lat_deg = 90.0f;
    if (lat_deg < -90.0f)
        lat_deg = -90.0f;

    // Normalize longitude to [-180, +180]
    while (lon_deg < -180.0f)
        lon_deg += 360.0f;
    while (lon_deg > 180.0f)
        lon_deg -= 360.0f;

    float xf = (lon_deg + 180.0f) / 360.0f * MAP_W;
    float yf = (90.0f - lat_deg) / 180.0f * MAP_H;

    x = MAP_X0 + (int16_t)roundf(xf);
    y = MAP_Y0 + (int16_t)roundf(yf);
}

// Plot great-circle path from home toward a given azimuth
void plotGreatCircle(float homeLat_deg, float homeLon_deg,
                     float azimuth_deg,
                     uint16_t color, uint8_t diameter)
{
    if (diameter == 0)
        diameter = 1;
    uint8_t radius = diameter / 2;

    // Convert to radians
    float lat1 = homeLat_deg * PI / 180.0f;
    float lon1 = homeLon_deg * PI / 180.0f;
    float brg = azimuth_deg * PI / 180.0f;

    float sinLat1 = sinf(lat1);
    float cosLat1 = cosf(lat1);
    float sinBrg = sinf(brg);
    float cosBrg = cosf(brg);

    Serial.printf("Plotting great-circle: lat=%.4f lon=%.4f brg=%.2f°\n",
                  homeLat_deg, homeLon_deg, azimuth_deg);

    float prevLat = homeLat_deg;
    bool goingNorth = (azimuth_deg < 90.0f || azimuth_deg > 270.0f);

    for (float theta_deg = 0.0f; theta_deg <= 180.0f; theta_deg += 0.5f)
    {
        float d = theta_deg * PI / 180.0f;
        float sinD = sinf(d);
        float cosD = cosf(d);

        // Forward geodesic
        float lat2 = asinf(sinLat1 * cosD + cosLat1 * sinD * cosBrg);
        lat2 = constrain(lat2, -PI / 2.0f, PI / 2.0f);

        float lon2;
        if (fabsf(sinBrg) < 1e-6f)
        {
            lon2 = lon1; // same meridian for due N/S
        }
        else
        {
            float yTerm = sinBrg * sinD * cosLat1;
            float xTerm = cosD - sinLat1 * sinf(lat2);
            lon2 = lon1 + atan2f(yTerm, xTerm);
            if (lon2 < -PI)
                lon2 += 2.0f * PI;
            else if (lon2 > PI)
                lon2 -= 2.0f * PI;
        }

        float lat2_deg = lat2 * 180.0f / PI;
        float lon2_deg = lon2 * 180.0f / PI;

        int16_t x, y;
        latLonToXY(lat2_deg, lon2_deg, x, y);

        if (x >= 0 && x < tft.width() && y >= 0 && y < tft.height())
            tft.fillCircle(x, y, radius, color);

        // --- Stop when latitude reverses (only for due N/S) ---
        if ((fabsf(azimuth_deg) < 1.0f || fabsf(azimuth_deg - 180.0f) < 1.0f))
        {
            if ((goingNorth && lat2_deg < prevLat) ||
                (!goingNorth && lat2_deg > prevLat))
            {
                break; // stop when motion reverses after pole
            }
            prevLat = lat2_deg;
        }

        // generic pole stop for all bearings
        if (fabsf(lat2_deg) >= 89.9f)
            break;
    }
}

