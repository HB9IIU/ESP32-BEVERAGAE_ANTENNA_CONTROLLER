void performFactoryResetAll()
{
    int16_t w = tft.width();
    int16_t h = tft.height();

    Serial.println(F("[RESET] Performing factory reset: erasing ALL NVS (all Preferences)."));

    // Simple message on TFT (no dialog, just info)
    tft.fillScreen(TFT_BLACK);
    tft.setTextColor(TFT_WHITE, TFT_BLACK);
    tft.setTextFont(4);
    tft.setTextSize(1);
    tft.setTextDatum(MC_DATUM);
    tft.drawString("Factory Reset...", w / 2, h / 2 - 20);
    tft.drawString("Erasing User Configuration", w / 2, h / 2 + 20);

    // Erase the entire NVS partition: all namespaces, including "config",
    // WiFi credentials, and anything stored by HB9IIUPortal.
    esp_err_t err = nvs_flash_erase();
    if (err == ESP_OK)
    {
        Serial.println(F("[RESET] nvs_flash_erase() OK."));
    }
    else
    {
        Serial.print(F("[RESET] nvs_flash_erase() ERROR: "));
        Serial.println((int)err);
    }

    // Re-init NVS so the next boot has a clean state
    err = nvs_flash_init();
    if (err == ESP_OK)
    {
        Serial.println(F("[RESET] nvs_flash_init() OK after erase."));
    }
    else
    {
        Serial.print(F("[RESET] nvs_flash_init() ERROR: "));
        Serial.println((int)err);
    }

    delay(2000);
    tft.fillScreen(TFT_BLACK);
    tft.drawString("Restarting...", w / 2, h / 2);
    delay(2000);

    ESP.restart(); // does not return
}

void setupElegantOTA()
{
    // HB9IIUPortal already connected WiFi.

  otaServer.on("/", []()
{
    otaServer.sendHeader("Location", "/update", true);
    otaServer.send(302, "text/plain", "");
});

    ElegantOTA.begin(&otaServer); // inject /update routes
    otaServer.begin();

    Serial.println(F("[OTA] ElegantOTA started on http://beverage.local/update"));
}
void checkAndApplyTFTCalibrationData(bool recalibrate)
{
    Serial.println(F("───────────────────────────────────────────────────────────────────────────────"));
    Serial.println(F("[INIT] 🖥️  TFT Touch Calibration Check"));
    Serial.println(F("───────────────────────────────────────────────────────────────────────────────"));

    if (recalibrate)
    {
        Serial.println(F("↪ Forced recalibration requested — launching calibration wizard..."));
        calibrateTFTscreen();
        return;
    }

    uint16_t calibrationData[5];
    bool dataValid = true;

    Serial.println(F("Reading stored calibration data from NVS namespace: 'TFT'"));
    preferences.begin("TFT", true); // read-only mode

    for (int i = 0; i < 5; i++)
    {
        calibrationData[i] = preferences.getUInt(("calib" + String(i)).c_str(), 0xFFFF);
        if (calibrationData[i] == 0xFFFF)
        {
            dataValid = false;
            Serial.printf("   ⚠️  calib%d = 0xFFFF → missing or invalid\n", i);
        }
        else
        {
            Serial.printf("   ✓ calib%d = %u\n", i, calibrationData[i]);
        }
    }
    preferences.end();

    if (dataValid)
    {
        tft.setTouch(calibrationData);
        Serial.println();
        Serial.println(F("✅ TFT touch calibration successfully retrieved and applied."));
        Serial.println(F("───────────────────────────────────────────────────────────────────────────────"));
    }
    else
    {
        Serial.println();
        Serial.println(F("❌ Calibration data invalid or incomplete."));
        Serial.println(F("↪ Starting full recalibration procedure..."));
        Serial.println(F("───────────────────────────────────────────────────────────────────────────────"));
        digitalWrite(TFT_BLP, HIGH);
        calibrateTFTscreen();
    }

    Serial.println();
}

void calibrateTFTscreen()
{
    uint16_t calibrationData[5];

    // Display recalibration message
    tft.fillScreen(TFT_BLACK);             // Clear screen
    tft.setTextColor(TFT_BLACK, TFT_GOLD); // Set text color (black on gold)
    tft.setFreeFont(&FreeSansBold12pt7b);  // Use custom free font
    tft.setCursor(10, 22);
    tft.fillRect(0, 0, 480, 30, TFT_GOLD);
    tft.print("   TFT TOUCHSCREEN CALIBRATION");
    tft.setTextColor(TFT_WHITE, TFT_BLACK);

    tft.setFreeFont(&FreeSans12pt7b);

    String instructions[] = {
        "Welcome to the initial touchscreen calibration.",
        "This procedure will only be required once.",
        "On the next screen you will see arrows",
        "appearing one after the other at each corner.",
        "Just tap them until completion.",
        "",
        "Tap anywhere on the screen to begin"};

    int16_t yPos = 100;

    for (String line : instructions)
    {
        int16_t xPos = (tft.width() - tft.textWidth(line)) / 2;
        tft.setCursor(xPos, yPos);
        tft.print(line);
        yPos += tft.fontHeight();
    }

    tft.setTextColor(TFT_GREEN, TFT_BLACK);
    tft.setCursor((tft.width() - tft.textWidth(instructions[6])) / 2, yPos - tft.fontHeight());
    tft.print(instructions[6]);

    while (true)
    {
        uint16_t x, y;
        if (tft.getTouch(&x, &y))
        {
            break;
        }
    }

    tft.fillScreen(TFT_BLACK);

    tft.calibrateTouch(calibrationData, TFT_GREEN, TFT_BLACK, 12);

    preferences.begin("TFT", false);
    for (int i = 0; i < 5; i++)
    {
        preferences.putUInt(("calib" + String(i)).c_str(), calibrationData[i]);
    }
    preferences.end();

    // Test calibration with dynamic feedback
    tft.fillScreen(TFT_BLACK);
    uint16_t x, y;
    int16_t lastX = -1, lastY = -1;
    String lastResult = "";

    tft.setTextColor(TFT_WHITE, TFT_BLACK);
    tft.setTextFont(4);
    String text = "Tap anywhere to test";
    tft.setCursor((tft.width() - tft.textWidth(text)) / 2, 8);
    tft.print(text);

    text = "Click Here to Exit";
    int16_t btn_w = tft.textWidth(text) + 20;
    int16_t btn_h = tft.fontHeight() + 12;
    int16_t btn_x = (tft.width() - btn_w) / 2;
    int16_t btn_y = 280;
    int16_t btn_r = 10;

    tft.fillRoundRect(btn_x, btn_y, btn_w, btn_h, btn_r, TFT_BLUE);
    tft.drawRoundRect(btn_x, btn_y, btn_w, btn_h, btn_r, TFT_WHITE);
    tft.setTextColor(TFT_WHITE, TFT_BLUE);
    tft.setCursor((tft.width() - tft.textWidth(text)) / 2, btn_y + 10);
    tft.print(text);

    while (true)
    {
        if (tft.getTouch(&x, &y))
        {
            String result = "x=" + String(x) + "  y=" + String(y) + "  p=" + String(tft.getTouchRawZ());

            tft.setTextColor(TFT_BLACK, TFT_BLACK);
            tft.setCursor(lastX, lastY);
            tft.print(lastResult);

            int16_t textWidth = tft.textWidth(result);
            int16_t xPos = (tft.width() - textWidth) / 2;
            int16_t yPos = (tft.height() - tft.fontHeight()) / 2;

            tft.setTextColor(TFT_GREEN, TFT_BLACK);
            tft.setCursor(xPos, yPos);
            tft.print(result);

            lastX = xPos;
            lastY = yPos;
            lastResult = result;

            tft.fillCircle(x, y, 2, TFT_RED);

            if (x > btn_x && x < btn_x + btn_w && y > btn_y && y < btn_y + btn_h)
            {
                Serial.println("Exit Touched");
                break;
            }
        }
    }
    tft.setTextSize(2);
    tft.fillScreen(TFT_BLACK);
}
void displayPicture(const char *imageName, int duration_ms)
{
    Serial.println();
    Serial.println(F("───────────────────────────────────────────────────────────────────────────────"));
    Serial.printf("[DISPLAY] 🖼️  Loading image: \"%s\"\n", imageName);
    Serial.println(F("───────────────────────────────────────────────────────────────────────────────"));

    const uint8_t *imageData = nullptr;
    uint32_t imageSize = 0;
    const char *resolvedName = imageName;

    // --- Image selection ---
    if (strcmp(imageName, "logo") == 0)
    {
        imageData = logo;
        imageSize = sizeof(logo);
    }
    else if (strcmp(imageName, "club") == 0)
    {
        imageData = club;
        imageSize = sizeof(club);
    }
    else if (strcmp(imageName, "remote") == 0)
    {
        imageData = remote;
        imageSize = sizeof(remote);
    }
    else if (strcmp(imageName, "azimuthalMap") == 0)
    {
        imageData = azimuthalMap;
        imageSize = sizeof(azimuthalMap);
    }
    else if (strcmp(imageName, "equirectangularMap") == 0)
    {
        imageData = equirectangularMap;
        imageSize = sizeof(equirectangularMap);
    }
    else
    {
        Serial.printf("⚠️  Unknown image name '%s' → defaulting to 'logo'\n", imageName);
        resolvedName = "logo";
        imageData = logo;
        imageSize = sizeof(logo);
    }

    // --- Draw buffer + callback setup ---
    static uint16_t lineBuffer[480];
    static TFT_eSPI *tftPtr = &tft;
    static PNG *pngPtr = &png;

    auto drawCallback = [](PNGDRAW *pDraw)
    {
        pngPtr->getLineAsRGB565(pDraw, lineBuffer, PNG_RGB565_BIG_ENDIAN, 0xFFFFFFFF);
        tftPtr->pushImage(0, pDraw->y, pDraw->iWidth, 1, lineBuffer);
    };

    // --- Decode and render ---
    Serial.printf("📦 Flash image resolved as '%s' (%lu bytes)\n", resolvedName, (unsigned long)imageSize);
    int16_t rc = png.openFLASH((uint8_t *)imageData, imageSize, drawCallback);

    if (rc == PNG_SUCCESS)
    {
        Serial.println(F("✅ PNG header parsed successfully."));
        Serial.printf("   ↳ Resolution   : %d x %d px\n", png.getWidth(), png.getHeight());
        Serial.printf("   ↳ Bit depth    : %d bpp\n", png.getBpp());
        Serial.printf("   ↳ Pixel format : %d\n", png.getPixelType());
        Serial.println();

        tft.startWrite();
        uint32_t t0 = millis();
        rc = png.decode(NULL, 0);
        uint32_t renderTime = millis() - t0;
        tft.endWrite();
        png.close();

        Serial.printf("🖥️  Image '%s' displayed successfully in %lu ms.\n", resolvedName, (unsigned long)renderTime);
    }
    else
    {
        Serial.printf("❌ PNG decode failed for '%s' (error %d)\n", resolvedName, rc);
    }

    digitalWrite(TFT_BLP, HIGH);
    delay(duration_ms);

    Serial.println(F("───────────────────────────────────────────────────────────────────────────────"));
    Serial.println();
}

void testTouchscreen()
{
    uint16_t x, y;
    if (tft.getTouch(&x, &y))
    {
        // Draw red touch dot
        tft.fillCircle(x, y, 4, TFT_RED);

        // Show coordinates at top center
        tft.setTextDatum(MC_DATUM);
        tft.setTextColor(TFT_YELLOW, TFT_BLACK);
        tft.setTextSize(2);
        char buf[40];
        sprintf(buf, "x=%d  y=%d", x, y);
        tft.fillRect(0, 0, tft.width(), 30, TFT_BLACK);
        tft.drawString(buf, tft.width() / 2, 10);
        Serial.printf("🖱️  Touch at: x=%d y=%d\n", x, y);
    }

    delay(50);
}

void encodertestTFT()
{
 digitalWrite(TFT_BLP, HIGH);
    // encoder test with TFT animation (improved visibility)
    Serial.println("=== Encoder test mode (TFT ring animation) ===");

    // better color contrast
    uint16_t ledOff = tft.color565(70, 70, 70); // dim gray (more visible)
    uint16_t ledOn = TFT_GREEN;                 // bright green
    uint16_t ledCenter = TFT_YELLOW;            // center flash color

    // clear screen
    tft.fillScreen(TFT_BLACK);
    tft.setTextColor(TFT_WHITE, TFT_BLACK);
    tft.setTextFont(2);
    tft.drawCentreString("Encoder Test Mode", tft.width() / 2, 10, 4);

    // ring geometry
    const uint8_t NUM_LEDS = 16;
    const int16_t cx = tft.width() / 2;
    const int16_t cy = tft.height() / 2 + 10;
    const int16_t RADIUS = 90;
    const uint8_t LED_R = 9;

    // precompute LED positions
    int16_t ledX[NUM_LEDS], ledY[NUM_LEDS];
    for (uint8_t i = 0; i < NUM_LEDS; i++)
    {
        float a = (360.0f / NUM_LEDS) * i * PI / 180.0f;
        ledX[i] = cx + RADIUS * sin(a);
        ledY[i] = cy - RADIUS * cos(a);
    }

    // draw ring LEDs off
    for (uint8_t i = 0; i < NUM_LEDS; i++)
        tft.fillCircle(ledX[i], ledY[i], LED_R, ledOff);

    // encoder tracking
    int dt = digitalRead(PIN_ENC_DT);
    int clk = digitalRead(PIN_ENC_CLK);
    uint8_t lastState = (dt << 1) | clk;
    int8_t encoderAccum = 0;
    int8_t ledIndex = 0;
    unsigned long counter = 0;

    // initial active LED
    tft.fillCircle(ledX[ledIndex], ledY[ledIndex], LED_R, ledOn);

    while (1)
    {
        dt = digitalRead(PIN_ENC_DT);
        clk = digitalRead(PIN_ENC_CLK);
        uint8_t currentState = (dt << 1) | clk;
        uint8_t index = (lastState << 2) | currentState;
        int8_t movement = encTable[index];

        if (movement != 0)
        {
            encoderAccum += movement;
            lastState = currentState;

            if (encoderAccum >= STEPS_PER_NOTCH)
            {
                encoderAccum = 0;
                counter++;
                tft.fillCircle(ledX[ledIndex], ledY[ledIndex], LED_R, ledOff);
                ledIndex = (ledIndex + 1) % NUM_LEDS;
                tft.fillCircle(ledX[ledIndex], ledY[ledIndex], LED_R, ledOn);
                Serial.printf("%lu CW\n", counter);
            }
            else if (encoderAccum <= -STEPS_PER_NOTCH)
            {
                encoderAccum = 0;
                counter++;
                tft.fillCircle(ledX[ledIndex], ledY[ledIndex], LED_R, ledOff);
                ledIndex = (ledIndex - 1 + NUM_LEDS) % NUM_LEDS;
                tft.fillCircle(ledX[ledIndex], ledY[ledIndex], LED_R, ledOn);
                Serial.printf("%lu CCW\n", counter);
            }
        }
        else
        {
            lastState = currentState;
        }

        // button animation
        if (digitalRead(PIN_ENC_SW) == LOW)
        {
            Serial.printf("[%lu] Button pressed\n", counter);

            // flash center with a "pulse" animation
            for (int r = 5; r <= 20; r += 3)
            {
                tft.fillCircle(cx, cy, r, ledCenter);
                delay(20);
            }
            delay(80);
            for (int r = 20; r >= 5; r -= 3)
            {
                tft.fillCircle(cx, cy, r, TFT_BLACK);
                delay(20);
            }

            // restore LED ring state
            for (uint8_t i = 0; i < NUM_LEDS; i++)
                tft.fillCircle(ledX[i], ledY[i], LED_R, ledOff);
            tft.fillCircle(ledX[ledIndex], ledY[ledIndex], LED_R, ledOn);

            delay(200);
        }

        delay(2);
    }
}

void drawWiFiIndicator()
{
    int16_t x = 20;
    int16_t y = 310;
    int barWidth = 5;
    int barHeight = 5;
    int barGap = 3;

    // clear background area for widget + text
    tft.fillRect(x - 3, y - 20, 60, 28, TFT_BLACK);

    if (WiFi.status() != WL_CONNECTED)
    {
        tft.setTextColor(TFT_RED, TFT_BLACK);
        tft.setTextFont(2);
        tft.drawString("x", x + 10, y - 8);
        tft.setTextFont(1);
        tft.drawString("No WiFi", x, y);
        return;
    }

    long rssi = WiFi.RSSI();          // dBm
    rssi = constrain(rssi, -90, -40); // safety limits

    // map RSSI -> 0..1 smooth factor
    float t = (float)(rssi + 90) / 50.0f;

    // smooth RGB gradient: red → yellow → green
    uint8_t r, g, b;
    if (t < 0.5f)
    {
        t *= 2.0f; // 0–1
        r = 255;
        g = (uint8_t)(t * 255);
        b = 0;
    }
    else
    {
        t = (t - 0.5f) * 2.0f; // 0–1
        r = (uint8_t)(255 * (1.0f - t));
        g = 255;
        b = 0;
    }
    uint16_t color = tft.color565(r, g, b);

    // discrete level for bar count
    uint8_t level = 0;
    if (rssi > -55)
        level = 4;
    else if (rssi > -65)
        level = 3;
    else if (rssi > -75)
        level = 2;
    else if (rssi > -85)
        level = 1;
    else
        level = 0;

    // draw all 4 bars freshly each time (prevents old color residue)
    for (uint8_t i = 0; i < 4; i++)
    {
        int barH = (i + 1) * barHeight;
        int bx = x + i * (barWidth + barGap);
        int by = y - barH - 5;

        if (i < level)
            tft.fillRect(bx, by, barWidth, barH, color);
        else
        {
            // clear bar area first to remove previous fill
            tft.fillRect(bx, by, barWidth, barH, TFT_BLACK);
            tft.drawRect(bx, by, barWidth, barH, TFT_DARKGREY);
        }
    }

    // --- Draw RSSI text below ---
    char buf[12];
    snprintf(buf, sizeof(buf), "%ld dB", rssi);
    tft.setTextFont(1);
    tft.setTextColor(TFT_LIGHTGREY, TFT_BLACK);
    tft.drawCentreString(buf, x + 20, y + 3, 1);
}
void drawMQTTIndicator()
{
    int16_t w = tft.width();
    int16_t h = tft.height();

    int16_t cx = w - 20; // bottom-right corner offset
    int16_t cy = h - 10;
    uint8_t r = 6;

    // --- Check states ---
    bool mqttOk = mqttClient.connected();
    bool haveHeartbeat = (lastClubStateMs != 0);
    bool heartbeatFresh = haveHeartbeat && (millis() - lastClubStateMs <= CLUB_TIMEOUT_MS);

    // --- Determine color + behavior ---
    uint16_t color;
    static unsigned long lastBlink = 0;
    static bool blinkState = false;
    unsigned long now = millis();

    if (!mqttOk)
    {
        color = TFT_RED;   // MQTT down
        blinkState = true; // solid
    }
    else if (!heartbeatFresh)
    {
        color = TFT_YELLOW; // waiting for heartbeat
        if (now - lastBlink >= 500)
        { // slow blink
            blinkState = !blinkState;
            lastBlink = now;
        }
    }
    else
    {
        // MQTT + CLUB alive → pulsing green glow
        static uint8_t pulse = 180;
        static int8_t dir = 4;
        pulse += dir;
        if (pulse >= 255 || pulse <= 150)
            dir = -dir;
        color = tft.color565(0, pulse, 0);
        blinkState = true;
    }

    // --- Draw ---
    if (blinkState)
    {
        // halo ring (soft white outline)
        tft.drawCircle(cx, cy, r + 2, TFT_WHITE);
        tft.fillCircle(cx, cy, r, color);
    }
    else
    {
        tft.fillCircle(cx, cy, r + 2, TFT_BLACK); // erase area when blinking off
    }

    // --- Optional debug label ---
    /*
    tft.setTextFont(1);
    tft.setTextColor(TFT_LIGHTGREY, TFT_BLACK);
    tft.drawRightString(mqttOk ? (heartbeatFresh ? "MQTT: OK" : "CLUB?") : "MQTT X", w - 5, h - 25, 1);
    */
}

